<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Invoice #<%= @booking.booking_number %></title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

  <style>
    @media print {
      .no-print { display: none !important; }
      body { font-size: 12px; }
    }

    .invoice-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 1rem;
      background: white;
    }

    .invoice-header {
      border-bottom: 3px solid #667eea;
      padding-bottom: 1rem;
      margin-bottom: 2rem;
    }

    .invoice-details {
      background: #f8f9fa;
      padding: 1rem;
      border-radius: 8px;
      margin-bottom: 2rem;
    }

    .invoice-items {
      margin-bottom: 2rem;
    }

    .invoice-total {
      border: 2px solid #667eea;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 1rem;
      border-radius: 8px;
    }

    .company-logo {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 2rem;
    }

    @media (max-width: 576px) {
      .invoice-container {
        padding: 0.5rem;
      }
    }
  </style>
</head>
<body>
  <div class="invoice-container">
    <!-- Header -->
    <div class="invoice-header">
      <div class="row align-items-center">
        <div class="col-auto">
          <div class="company-logo">
            <i class="fas fa-leaf"></i>
          </div>
        </div>
        <div class="col">
          <h3 class="mb-0">Dhanvantri Naturals</h3>
          <p class="mb-0 text-muted">Natural Health Products</p>
        </div>
        <div class="col-auto text-end">
          <h4 class="mb-0">INVOICE</h4>
          <p class="mb-0 text-muted">#<%= @booking.booking_number %></p>
        </div>
      </div>
    </div>

    <!-- Invoice Details -->
    <div class="invoice-details">
      <div class="row">
        <div class="col-md-6">
          <h6 class="text-primary">Bill To:</h6>
          <strong><%= @booking.customer_name || 'Customer' %></strong><br>
          <% if @booking.customer_phone.present? %>
            <i class="fas fa-phone me-1"></i><%= @booking.customer_phone %><br>
          <% end %>
          <% if @booking.delivery_address.present? %>
            <i class="fas fa-map-marker-alt me-1"></i><%= @booking.delivery_address %>
          <% end %>
        </div>
        <div class="col-md-6 text-end">
          <h6 class="text-primary">Invoice Details:</h6>
          <strong>Date:</strong> <%= @booking.created_at.strftime('%d %B, %Y') %><br>
          <strong>Time:</strong> <%= @booking.created_at.strftime('%I:%M %p') %><br>
          <strong>Status:</strong> <%= @booking.status&.humanize || 'Draft' %><br>
          <strong>Payment:</strong>
          <% case @booking.payment_status %>
          <% when 'paid' %>
            <span class="text-success">Paid</span>
          <% when 'partial' %>
            <span class="text-warning">Partial</span>
          <% else %>
            <span class="text-danger">Unpaid</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Items Table -->
    <div class="invoice-items">
      <h6 class="text-primary mb-3">Items:</h6>
      <div class="table-responsive">
        <table class="table table-bordered">
          <thead class="table-light">
            <tr>
              <th>Description</th>
              <th class="text-center">Quantity</th>
              <th class="text-end">Rate</th>
              <th class="text-end">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% if @booking.booking_items&.any? %>
              <% @booking.booking_items.each do |item| %>
                <tr>
                  <td>
                    <strong><%= item.product&.name || 'Product' %></strong>
                    <% if item.product&.description %>
                      <br><small class="text-muted"><%= item.product.description %></small>
                    <% end %>
                  </td>
                  <td class="text-center"><%= item.quantity || 1 %></td>
                  <td class="text-end">₹<%= item.price || 0 %></td>
                  <td class="text-end">₹<%= (item.quantity || 1) * (item.price || 0) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="2">
                  <strong>Booking Service</strong><br>
                  <small class="text-muted">Service booking fee</small>
                </td>
                <td class="text-center">1</td>
                <td class="text-end">₹<%= @booking.total_amount %></td>
                <td class="text-end">₹<%= @booking.total_amount %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Total -->
    <div class="invoice-total">
      <div class="row align-items-center">
        <div class="col">
          <h5 class="mb-0">Total Amount</h5>
        </div>
        <div class="col-auto">
          <h3 class="mb-0">₹<%= @booking.total_amount %></h3>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-4 pt-4 border-top">
      <div class="row">
        <div class="col-md-6">
          <h6 class="text-primary">Payment Instructions:</h6>
          <p class="small mb-0">
            • Payment can be made via Cash, UPI, or Bank Transfer<br>
            • Please keep this invoice for your records<br>
            • For any queries, contact us at support@dhanvantri-naturals.com
          </p>
        </div>
        <div class="col-md-6 text-end">
          <h6 class="text-primary">Company Details:</h6>
          <p class="small mb-0">
            <strong>Dhanvantri Naturals</strong><br>
            Natural Health Products<br>
            Email: info@dhanvantri-naturals.com<br>
            Phone: +91 9999999999
          </p>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="no-print mt-4 pt-3 border-top">
      <div class="row">
        <div class="col-6">
          <button onclick="window.history.back()" class="btn btn-outline-secondary w-100">
            <i class="fas fa-arrow-left me-2"></i> Back
          </button>
        </div>
        <div class="col-6">
          <button onclick="window.print()" class="btn btn-primary w-100">
            <i class="fas fa-print me-2"></i> Print/Save PDF
          </button>
        </div>
      </div>

      <div class="mt-2">
        <% if @booking.customer_phone.present? %>
          <a href="https://wa.me/+91<%= @booking.customer_phone.gsub(/\D/, '') %>?text=Hello%20<%= @booking.customer_name %>, please find your invoice for booking #<%= @booking.booking_number %>. Total amount: ₹<%= @booking.total_amount %>"
             class="btn btn-success w-100"
             target="_blank">
            <i class="fab fa-whatsapp me-2"></i> Share via WhatsApp
          </a>
        <% end %>
      </div>
    </div>
  </div>

  <script>
    // Auto print on mobile devices if requested
    if (window.location.search.includes('print=true')) {
      setTimeout(() => {
        window.print();
      }, 1000);
    }

    // Format for printing
    window.addEventListener('beforeprint', function() {
      document.body.style.background = 'white';
    });

    // Restore after printing
    window.addEventListener('afterprint', function() {
      document.body.style.background = '';
    });
  </script>
</body>
</html>