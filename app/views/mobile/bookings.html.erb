<!-- Quick Stats -->
<div class="row mb-3">
  <div class="col-6">
    <div class="card card-modern text-center">
      <div class="card-body py-3">
        <h5 class="mb-1"><%= @bookings.count %></h5>
        <small class="text-muted">Total Bookings</small>
      </div>
    </div>
  </div>
  <div class="col-6">
    <div class="card card-modern text-center">
      <div class="card-body py-3">
        <h5 class="mb-1">₹<%= @bookings.sum(:total_amount) %></h5>
        <small class="text-muted">Total Value</small>
      </div>
    </div>
  </div>
</div>

<!-- New Booking Button -->
<div class="mb-3">
  <%= link_to mobile_new_booking_path, class: "btn btn-primary-modern btn-modern w-100" do %>
    <i class="fas fa-plus me-2"></i> Create New Booking
  <% end %>
</div>

<!-- Bookings List -->
<% if @bookings.any? %>
  <% @bookings.each do |booking| %>
    <div class="card card-modern mb-3">
      <div class="card-header card-header-modern d-flex justify-content-between align-items-center">
        <div>
          <h6 class="mb-0">#<%= booking.booking_number %></h6>
          <small class="opacity-75"><%= booking.created_at.strftime('%d %b, %Y') %></small>
        </div>
        <div class="text-end">
          <div class="badge bg-light text-dark">
            <%= booking.status&.humanize || 'Draft' %>
          </div>
        </div>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-8">
            <% if booking.customer_name.present? %>
              <p class="mb-1"><i class="fas fa-user me-2 text-muted"></i><%= booking.customer_name %></p>
            <% end %>
            <% if booking.customer_phone.present? %>
              <p class="mb-1"><i class="fas fa-phone me-2 text-muted"></i><%= booking.customer_phone %></p>
            <% end %>
            <p class="mb-0"><i class="fas fa-rupee-sign me-2 text-muted"></i>₹<%= booking.total_amount %></p>
          </div>
          <div class="col-4 text-end">
            <%= link_to mobile_booking_path(booking), class: "btn btn-sm btn-outline-primary btn-modern mb-1" do %>
              <i class="fas fa-eye"></i>
            <% end %>
            <br>
            <%= link_to mobile_invoice_path(booking), class: "btn btn-sm btn-success-modern btn-modern", target: "_blank" do %>
              <i class="fas fa-file-invoice"></i>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-5">
    <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
    <h4 class="text-muted">No Bookings Yet</h4>
    <p class="text-muted">Create your first booking to get started</p>
    <%= link_to mobile_new_booking_path, class: "btn btn-primary-modern btn-modern" do %>
      <i class="fas fa-plus me-2"></i> Create Booking
    <% end %>
  </div>
<% end %>

<script>
// Auto refresh every 30 seconds
setInterval(function() {
  window.location.reload();
}, 30000);

// Pull to refresh simulation
let isRefreshing = false;
let startY = 0;

document.addEventListener('touchstart', function(e) {
  startY = e.touches[0].clientY;
}, { passive: true });

document.addEventListener('touchmove', function(e) {
  if (window.pageYOffset === 0 && e.touches[0].clientY > startY + 100 && !isRefreshing) {
    isRefreshing = true;

    // Show refresh indicator
    const refreshIndicator = document.createElement('div');
    refreshIndicator.innerHTML = '<i class="fas fa-sync fa-spin"></i> Refreshing...';
    refreshIndicator.className = 'alert alert-info text-center position-fixed';
    refreshIndicator.style.cssText = 'top: 70px; left: 50%; transform: translateX(-50%); z-index: 9999;';
    document.body.appendChild(refreshIndicator);

    setTimeout(() => {
      window.location.reload();
    }, 1000);
  }
}, { passive: true });
</script>