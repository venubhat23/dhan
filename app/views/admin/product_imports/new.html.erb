<div class="container-fluid">
  <div class="row">
    <div class="col-md-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4 class="card-title mb-0">
            <i class="fas fa-upload me-2"></i>
            Import Dhanvantri Products
          </h4>
          <%= link_to "Back to Products", admin_products_path, class: "btn btn-secondary" %>
        </div>

        <div class="card-body">
          <!-- Instructions Card -->
          <div class="alert alert-info">
            <h5><i class="fas fa-info-circle me-2"></i>CSV Import Instructions</h5>
            <p class="mb-2">CSV Columns (* = Required, others optional):</p>
            <div class="row">
              <div class="col-md-6">
                <h6 class="text-primary">Required Fields:</h6>
                <ul class="mb-3">
                  <li><strong>Item*</strong> - Product name</li>
                  <li><strong>Category*</strong> - Category name or ID</li>
                </ul>

                <h6 class="text-success">Core Pricing:</h6>
                <ul class="mb-3">
                  <li><strong>Purchase Price</strong> - Cost from supplier</li>
                  <li><strong>Cost Price</strong> - MRP/Retail price</li>
                  <li><strong>Wholesale Price</strong> - B2B price</li>
                </ul>

                <h6 class="text-info">Product Info:</h6>
                <ul class="mb-3">
                  <li>Description, SKU, Stock, Weight</li>
                  <li>Dimensions, Unit Type, Product Type</li>
                  <li>Status (active/inactive/draft)</li>
                </ul>

                <h6 class="text-warning">GST & Compliance:</h6>
                <ul class="mb-3">
                  <li>GST Enabled, GST Percentage</li>
                  <li>HSN Code, CGST, SGST, IGST</li>
                </ul>
              </div>

              <div class="col-md-6">
                <h6 class="text-secondary">Discount Settings:</h6>
                <ul class="mb-3">
                  <li>Is Discounted, Discount Type</li>
                  <li>Discount Value, Discount Amount</li>
                  <li>Original Price, Discount Price</li>
                </ul>

                <h6 class="text-dark">SEO & Marketing:</h6>
                <ul class="mb-3">
                  <li>Tags, Meta Title, Meta Description</li>
                  <li>Image URL</li>
                </ul>

                <h6 class="text-purple">Advanced Features:</h6>
                <ul class="mb-3">
                  <li>Is Subscription Enabled</li>
                  <li>Is Occasional Product</li>
                  <li>Occasional Dates & Description</li>
                  <li>Minimum Stock Alert</li>
                </ul>

                <div class="alert alert-success p-2">
                  <small><i class="fas fa-lightbulb me-1"></i><strong>Pro Tip:</strong> Leave optional fields blank if not needed. The system will use smart defaults!</small>
                </div>
              </div>
            </div>
            <p class="mt-2 mb-0"><small>* Required fields</small></p>
          </div>

          <!-- Sample CSV Format -->
          <div class="alert alert-success">
            <h6><i class="fas fa-table me-2"></i>Sample CSV Formats:</h6>

            <div class="mb-3">
              <strong>1. Minimal Import (Required + Core Pricing):</strong>
              <table class="table table-sm table-bordered mb-2">
                <thead class="table-dark">
                  <tr>
                    <th>Item*</th>
                    <th>Category*</th>
                    <th>Purchase Price</th>
                    <th>Cost Price</th>
                    <th>Wholesale Price</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Organic Rice 1kg</td>
                    <td>Grains</td>
                    <td>100</td>
                    <td>150</td>
                    <td>140</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="mb-3">
              <strong>2. Extended Import (with optional fields):</strong>
              <div class="table-responsive">
                <table class="table table-sm table-bordered mb-2" style="font-size: 11px;">
                  <thead class="table-secondary">
                    <tr>
                      <th>Item*</th>
                      <th>Category*</th>
                      <th>Purchase Price</th>
                      <th>Cost Price</th>
                      <th>Description</th>
                      <th>Stock</th>
                      <th>GST Enabled</th>
                      <th>GST %</th>
                      <th>HSN Code</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Premium Tea</td>
                      <td>Beverages</td>
                      <td>80</td>
                      <td>120</td>
                      <td>Aromatic tea</td>
                      <td>30</td>
                      <td>true</td>
                      <td>12</td>
                      <td>0902</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="alert alert-warning py-2">
              <small><i class="fas fa-download me-1"></i><strong>Download the complete template</strong> to see all 36+ available fields with sample data!</small>
            </div>
          </div>

          <!-- Available Categories -->
          <div class="alert alert-warning">
            <h6><i class="fas fa-list me-2"></i>Available Categories:</h6>
            <div class="row">
              <% @categories.each do |category| %>
                <div class="col-md-3 col-sm-6">
                  <span class="badge badge-outline-secondary me-1">
                    <%= category.name %> (ID: <%= category.id %>)
                  </span>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Upload Form -->
          <%= form_with url: admin_product_imports_path, method: :post, multipart: true, local: true, class: "mt-4" do |form| %>
            <div class="row justify-content-center">
              <div class="col-md-8">
                <div class="card border-primary">
                  <div class="card-body text-center">
                    <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>

                    <div class="mb-3">
                      <%= form.file_field :csv_file,
                            accept: ".csv",
                            required: true,
                            class: "form-control form-control-lg",
                            id: "csv_file" %>
                    </div>

                    <div class="d-grid gap-2">
                      <%= form.submit "Import Products",
                            class: "btn btn-primary btn-lg",
                            data: {
                              confirm: "Are you sure you want to import these products? This will update existing products with the same name.",
                              disable_with: "Importing..."
                            } %>
                    </div>

                    <small class="text-muted d-block mt-2">
                      Only CSV files are accepted. Maximum file size: 10MB
                    </small>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Processing Notes -->
          <div class="mt-4">
            <h6>Processing Notes:</h6>
            <ul class="list-unstyled">
              <li><i class="fas fa-check text-success me-2"></i>Existing products with the same name will be updated</li>
              <li><i class="fas fa-plus text-info me-2"></i>New products will be created with default stock of 0</li>
              <li><i class="fas fa-shield-alt text-warning me-2"></i>All products will be set to 'active' status</li>
              <li><i class="fas fa-tag text-primary me-2"></i>Product type will be set to 'Grocery' and unit to 'Piece'</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const fileInput = document.getElementById('csv_file');

  fileInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      // Validate file type
      if (!file.name.toLowerCase().endsWith('.csv')) {
        alert('Please select a CSV file.');
        this.value = '';
        return;
      }

      // Validate file size (10MB max)
      if (file.size > 10 * 1024 * 1024) {
        alert('File size must be less than 10MB.');
        this.value = '';
        return;
      }

      // Show file info
      const fileName = file.name;
      const fileSize = (file.size / 1024).toFixed(2);
      console.log(`Selected file: ${fileName} (${fileSize} KB)`);
    }
  });
});
</script>