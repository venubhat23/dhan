<% content_for :title, "Delivery Settings" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><i class="fas fa-truck me-2"></i>Delivery Charges Management</h2>
    <p class="text-muted mb-0">Manage delivery charges by pincode area</p>
  </div>
  <%= link_to new_admin_delivery_setting_path, class: "btn btn-primary" do %>
    <i class="fas fa-plus me-1"></i> Add New Pincode
  <% end %>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-primary border-2">
      <div class="card-body text-center">
        <i class="fas fa-map-marker-alt fa-2x text-primary mb-2"></i>
        <h6 class="text-muted mb-1">Total Pincodes</h6>
        <h3 class="text-primary fw-bold"><%= @delivery_charges.count %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-success border-2">
      <div class="card-body text-center">
        <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
        <h6 class="text-muted mb-1">Active Zones</h6>
        <h3 class="text-success fw-bold"><%= @delivery_charges.active.count %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-warning border-2">
      <div class="card-body text-center">
        <i class="fas fa-pause-circle fa-2x text-warning mb-2"></i>
        <h6 class="text-muted mb-1">Inactive Zones</h6>
        <h3 class="text-warning fw-bold"><%= @delivery_charges.inactive.count %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-info border-2">
      <div class="card-body text-center">
        <i class="fas fa-rupee-sign fa-2x text-info mb-2"></i>
        <h6 class="text-muted mb-1">Avg. Charge</h6>
        <h3 class="text-info fw-bold">₹<%= @delivery_charges.active.average(:charge_amount)&.round(2) || 0 %></h3>
      </div>
    </div>
  </div>
</div>

<!-- Flash messages -->
<% if notice %>
  <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
    <%= notice %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% end %>

<!-- Delivery Charges Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if @delivery_charges.empty? %>
      <div class="text-center py-5">
        <i class="fas fa-truck fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">No delivery charges configured</h5>
        <p class="text-muted mb-4">Add delivery charges for different pincodes to get started.</p>
        <%= link_to new_admin_delivery_setting_path, class: "btn btn-primary" do %>
          <i class="fas fa-plus me-1"></i> Add First Delivery Charge
        <% end %>
      </div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th>Pincode</th>
              <th>Area</th>
              <th>Charge Amount</th>
              <th>Status</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @delivery_charges.each do |dc| %>
              <tr>
                <td><strong><%= dc.pincode %></strong></td>
                <td><%= dc.area.presence || '<span class="text-muted">Not specified</span>'.html_safe %></td>
                <td class="text-success fw-bold"><%= dc.formatted_charge %></td>
                <td>
                  <% if dc.is_active? %>
                    <span class="badge bg-success">Active</span>
                  <% else %>
                    <span class="badge bg-secondary">Inactive</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <div class="btn-group" role="group">
                    <%= link_to edit_admin_delivery_setting_path(dc), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="fas fa-edit"></i> Edit
                    <% end %>
                    <%= button_to toggle_status_admin_delivery_setting_path(dc),
                        method: :patch,
                        class: "btn btn-sm btn-outline-#{dc.is_active? ? 'warning' : 'success'}" do %>
                      <i class="fas fa-<%= dc.is_active? ? 'pause' : 'play' %>"></i>
                      <%= dc.is_active? ? 'Deactivate' : 'Activate' %>
                    <% end %>
                    <%= button_to admin_delivery_setting_path(dc),
                        method: :delete,
                        class: "btn btn-sm btn-outline-danger",
                        data: { confirm: "Delete delivery charge for #{dc.pincode}?" } do %>
                      <i class="fas fa-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
