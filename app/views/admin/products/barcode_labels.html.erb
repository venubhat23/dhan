<!DOCTYPE html>
<html>
<head>
  <title>Product Barcode Labels</title>
  <style>
    @media print {
      .no-print { display: none !important; }
    }

    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 20px;
    }

    .label-page {
      width: 210mm;
      margin: 0 auto;
    }

    .label-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10mm;
      margin-bottom: 10mm;
    }

    .barcode-label {
      width: 60mm;
      height: 40mm;
      border: 1px solid #ddd;
      padding: 3mm;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-sizing: border-box;
      page-break-inside: avoid;
    }

    .product-name {
      font-size: 9pt;
      font-weight: bold;
      text-align: center;
      line-height: 1.2;
      max-height: 12mm;
      overflow: hidden;
      margin-bottom: 2mm;
    }

    .barcode-container {
      text-align: center;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .barcode-visual {
      height: 15mm;
      background: repeating-linear-gradient(
        to right,
        #000 0px, #000 1px,
        #fff 1px, #fff 2px
      );
      margin: 2mm 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: bold;
      font-size: 8pt;
    }

    .barcode-number {
      font-size: 8pt;
      font-family: monospace;
      text-align: center;
      margin: 1mm 0;
    }

    .price-info {
      display: flex;
      justify-content: space-between;
      font-size: 8pt;
      margin-top: 2mm;
    }

    .retail-price {
      font-weight: bold;
      color: #000;
    }

    .wholesale-price {
      color: #0066cc;
    }

    .controls {
      margin-bottom: 20px;
      padding: 15px;
      background: #f5f5f5;
      border-radius: 5px;
    }

    .controls h3 {
      margin: 0 0 15px 0;
    }

    .form-group {
      margin-bottom: 10px;
    }

    .form-group label {
      display: inline-block;
      width: 120px;
      font-weight: bold;
    }

    .form-group select, .form-group input {
      padding: 5px;
      border: 1px solid #ddd;
      border-radius: 3px;
    }

    .btn {
      padding: 8px 16px;
      background: #007bff;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      margin-right: 10px;
    }

    .btn:hover {
      background: #0056b3;
    }

    .btn-secondary {
      background: #6c757d;
    }

    .btn-secondary:hover {
      background: #5a6268;
    }
  </style>
</head>
<body>
  <div class="no-print controls">
    <h3>🏷️ Barcode Label Generator</h3>

    <div style="background: #e7f3ff; padding: 10px; margin-bottom: 15px; border-radius: 4px;">
      <strong>📊 Current Selection:</strong>
      <%= @products.count %> products |
      Total labels: <%= (@products.count * (params[:quantity]&.to_i || 1)) %>
      <% if @products.count > 0 %>
        | First: <%= @products.first.name.truncate(20) %>
        <% if @products.count > 1 %>
          | Last: <%= @products.last.name.truncate(20) %>
        <% end %>
      <% end %>
    </div>

    <div class="form-group">
      <label>Filter Products:</label>
      <select onchange="updateFilter('filter', this.value)">
        <option value="" <%= 'selected' if params[:filter].blank? %>>All Active Products</option>
        <option value="all" <%= 'selected' if params[:filter] == 'all' %>>All Products (50 max)</option>
        <option value="recent" <%= 'selected' if params[:filter] == 'recent' %>>Recent Products (15)</option>
      </select>

      <select onchange="updateFilter('category_id', this.value)" style="margin-left: 10px;">
        <option value="">All Categories</option>
        <% Category.all.each do |category| %>
          <option value="<%= category.id %>" <%= 'selected' if params[:category_id] == category.id.to_s %>>
            <%= category.name %> (<%= category.products.active.count %>)
          </option>
        <% end %>
      </select>
    </div>

    <div class="form-group">
      <label>Labels per Product:</label>
      <select onchange="updateFilter('quantity', this.value)">
        <option value="1" <%= 'selected' if params[:quantity] == '1' || params[:quantity].blank? %>>1 Label</option>
        <option value="2" <%= 'selected' if params[:quantity] == '2' %>>2 Labels</option>
        <option value="3" <%= 'selected' if params[:quantity] == '3' %>>3 Labels</option>
        <option value="5" <%= 'selected' if params[:quantity] == '5' %>>5 Labels</option>
        <option value="10" <%= 'selected' if params[:quantity] == '10' %>>10 Labels</option>
      </select>
    </div>

    <div class="form-group">
      <button class="btn" onclick="window.print()">🖨️ Print <%= (@products.count * (params[:quantity]&.to_i || 1)) %> Labels</button>
      <button class="btn btn-secondary" onclick="window.location.reload()">🔄 Refresh</button>
      <button class="btn btn-secondary" onclick="window.history.back()">← Back to Products</button>
    </div>
  </div>

  <div class="label-page">
    <%
      products = @products.presence || [Product.find(62)]
      quantity = params[:quantity]&.to_i || 1
      label_count = 0
    %>

    <div class="label-grid">
      <% products.each do |product| %>
        <% quantity.times do |copy_number| %>
          <div class="barcode-label">
            <div class="product-name">
              <%= product.name.truncate(30) %>
              <% if quantity > 1 %>
                <small style="display: block; font-size: 7pt; color: #666;">
                  Copy <%= copy_number + 1 %> of <%= quantity %>
                </small>
              <% end %>
            </div>

            <div class="barcode-container">
              <div class="barcode-visual">
                <%= product.barcode || 'NO-BARCODE' %>
              </div>
              <div class="barcode-number">
                <%= product.respond_to?(:barcode_display_format) ? product.barcode_display_format : (product.barcode || 'N/A') %>
              </div>
              <% if product.sku.present? %>
                <div style="font-size: 6pt; color: #888; margin-top: 1mm;">
                  SKU: <%= product.sku %>
                </div>
              <% end %>
            </div>

            <div class="price-info">
              <div class="retail-price">₹<%= product.price || '0.00' %></div>
              <% if product.respond_to?(:has_wholesale_pricing?) && product.has_wholesale_pricing? %>
                <div class="wholesale-price">B2B: ₹<%= product.wholesale_price %></div>
              <% else %>
                <div class="wholesale-price">B2B: ₹<%= (product.price.to_f * 0.85).round(2) %></div>
              <% end %>
            </div>
          </div>

          <%
            label_count += 1
            if label_count % 9 == 0 && !(product == products.last && copy_number == quantity - 1)
          %>
            </div>
            <div class="label-grid">
          <% end %>
        <% end %>
      <% end %>
    </div>

    <% if products.empty? %>
      <div style="text-align: center; padding: 40px; color: #666;">
        <h3>No products found</h3>
        <p>Try adjusting your filters or adding some products with barcodes.</p>
      </div>
    <% end %>
  </div>

  <script>
    function updateFilter(param, value) {
      const url = new URL(window.location);

      // Update the specific parameter
      if (value && value !== '') {
        url.searchParams.set(param, value);
      } else {
        url.searchParams.delete(param);
      }

      // Navigate to the updated URL
      window.location.href = url.toString();
    }

    // Auto-print dialog for better UX
    document.addEventListener('DOMContentLoaded', function() {
      console.log('Barcode labels ready for <%= products.count %> products');

      // Show helpful info
      const productCount = <%= @products.count %>;
      const labelCount = productCount * <%= params[:quantity]&.to_i || 1 %>;

      if (productCount > 50) {
        alert('⚠️ Many labels detected (' + labelCount + '). Consider printing in batches for better performance.');
      }
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', function(e) {
      if (e.ctrlKey && e.key === 'p') {
        e.preventDefault();
        window.print();
      }
      if (e.key === 'Escape') {
        window.history.back();
      }
    });
  </script>
</body>
</html>