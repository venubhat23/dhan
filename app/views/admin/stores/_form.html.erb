<%= form_with(model: [:admin, store], local: true, onsubmit: "return validateForm();") do |form| %>
  <% if store.errors.any? %>
    <div class="alert alert-danger alert-dismissible" role="alert">
      <h6 class="alert-heading mb-1">Please fix the following errors:</h6>
      <ul class="mb-0">
        <% store.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <!-- Single Page Store Creation -->
  <div class="store-creation-form">

    <!-- Store Information Section -->
      <div class="card mb-4 border-0 shadow-lg">
        <div class="card-header text-white border-0 p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
          <div class="d-flex align-items-center">
            <div class="page-icon me-3">
              <i class="ri-store-2-line" style="font-size: 2.5rem;"></i>
            </div>
            <div>
              <h4 class="card-title mb-1 fw-bold">Store Information</h4>
              <p class="mb-0 text-white-75">Enter the basic details for your new store</p>
            </div>
          </div>
        </div>
        <div class="card-body p-4">
      <div class="row mb-3">
        <div class="col-md-12">
          <label class="form-label">Store Name <span class="text-danger">*</span></label>
          <%= form.text_field :name, class: "form-control", placeholder: "Enter store name", required: true %>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Address <span class="text-danger">*</span></label>
        <%= form.text_area :address, class: "form-control", rows: 3, placeholder: "Enter complete address", required: true %>
      </div>

      <div class="row mb-3">
        <div class="col-md-4">
          <label class="form-label">City <span class="text-danger">*</span></label>
          <%= form.text_field :city, class: "form-control", placeholder: "Enter city", required: true %>
        </div>
        <div class="col-md-4">
          <label class="form-label">State <span class="text-danger">*</span></label>
          <%= form.text_field :state, class: "form-control", placeholder: "Enter state", required: true %>
        </div>
        <div class="col-md-4">
          <label class="form-label">Pincode <span class="text-danger">*</span></label>
          <%= form.text_field :pincode, class: "form-control", placeholder: "6-digit pincode", required: true %>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-12">
          <label class="form-label">GST Number</label>
          <%= form.text_field :gst_no, class: "form-control", placeholder: "Enter GST number (optional)" %>
          <small class="text-muted">15-character GST number (optional)</small>
        </div>
      </div>

      <%= form.hidden_field :status, value: true %>
      <%= form.hidden_field :inventory_management_enabled, value: true %>
      <%= form.hidden_field :contact_person, value: "Store Administrator" %>
      <%= form.hidden_field :contact_mobile, value: "9876543210" %>
      <%= form.hidden_field :email, value: "" %>
    </div>

    <!-- Admin Setup Section -->
    <% if store.new_record? %>
    <div class="admin-setup-section">
      <div class="card mb-4 border-0 shadow-lg">
        <div class="card-header text-white border-0 p-4" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
          <div class="d-flex align-items-center">
            <div class="page-icon me-3">
              <i class="ri-user-settings-line" style="font-size: 2.5rem;"></i>
            </div>
            <div>
              <h4 class="card-title mb-1 fw-bold">Store Admin Setup</h4>
              <p class="mb-0 text-white-75">Create an admin account to manage this store</p>
            </div>
          </div>
        </div>
        <div class="card-body p-4">
          <div class="row mb-4">
            <div class="col-12">
              <div class="form-check form-switch">
                <%= form.check_box :create_admin_user, class: "form-check-input", checked: true, onchange: "toggleAdminSection()" %>
                <label class="form-check-label fw-semibold">Create Store Admin Account</label>
                <div class="form-text">
                  <i class="ri-information-line me-1"></i>Enable this to create a dedicated admin user for store management
                </div>
              </div>
            </div>
          </div>
          <div id="admin-section">
        <div class="row mb-3">
          <div class="col-md-6">
            <label class="form-label">Admin Username <span class="text-danger">*</span></label>
            <%= form.text_field :admin_username, class: "form-control", placeholder: "Enter admin username", id: "admin_username", required: true %>
            <small class="text-muted">This will be used to login to the store admin panel</small>
          </div>
          <div class="col-md-6">
            <label class="form-label">Admin Password <span class="text-danger">*</span></label>
            <%= form.password_field :admin_password, class: "form-control", placeholder: "Minimum 6 characters", id: "admin_password", required: true %>
            <small class="text-muted">Strong password for store admin access</small>
          </div>
        </div>

        <%= form.hidden_field :admin_email, value: "" %>
        <%= form.hidden_field :admin_first_name, value: "Store" %>
        <%= form.hidden_field :admin_last_name, value: "Admin" %>
        <%= form.hidden_field :admin_mobile, value: "1234567890" %>
      </div>
    </div>

    <!-- Inventory Allocation Section -->
    <div class="inventory-allocation-section">
      <div class="card mb-4 border-0 shadow-lg">
        <div class="card-header text-white border-0 p-4" style="background: linear-gradient(135deg, #ff6b6b 0%, #ffa726 100%);">
          <div class="d-flex align-items-center">
            <div class="page-icon me-3">
              <i class="ri-box-3-line" style="font-size: 2.5rem;"></i>
            </div>
            <div>
              <h4 class="card-title mb-1 fw-bold">Initial Inventory Allocation</h4>
              <p class="mb-0 text-white-75">Set up your store's initial product inventory</p>
            </div>
          </div>
        </div>
        <div class="card-body p-0">

      <!-- Product Selection -->
      <div class="inventory-allocation-content">
        <div class="card mb-4 inventory-allocation-card border-0 shadow-lg">
          <div class="card-header text-white border-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h5 class="card-title mb-1 fw-bold">
                  <i class="ri-box-3-line me-2"></i>Step 1: Select Products for Allocation
                </h5>
                <small class="text-white-75">Choose products from central inventory to transfer to this new store</small>
              </div>
              <div class="text-end">
                <button type="button" class="btn btn-light btn-sm me-2 shadow-sm" onclick="refreshInventoryData()" title="Refresh Inventory">
                  <i class="ri-refresh-line me-1"></i>Refresh
                </button>
                <button type="button" class="btn btn-outline-light btn-sm shadow-sm" onclick="optimizeAllocation()" title="Smart Auto-Select">
                  <i class="ri-magic-line me-1"></i>Smart Select
                </button>
              </div>
            </div>
          </div>
          <div class="card-body p-0">
        <% if @available_products&.any? %>
          <!-- Enhanced Search and Filter Controls -->
          <div class="bg-white border-bottom p-4">
            <div class="row g-3 align-items-end">
              <div class="col-lg-5">
                <label class="form-label text-dark fw-semibold mb-2">
                  <i class="ri-search-line me-1 text-primary"></i>Search Products
                </label>
                <div class="input-group shadow-sm">
                  <span class="input-group-text bg-white border-end-0">
                    <i class="ri-search-line text-muted"></i>
                  </span>
                  <input type="text" id="product-search" class="form-control border-start-0 ps-0" placeholder="Search by name, SKU, or category...">
                  <button class="btn btn-outline-secondary border-start-0" type="button" onclick="document.getElementById('product-search').value=''; filterProducts();">
                    <i class="ri-close-line"></i>
                  </button>
                </div>
              </div>
              <div class="col-lg-3">
                <label class="form-label text-dark fw-semibold mb-2">
                  <i class="ri-filter-line me-1 text-primary"></i>Filter by Category
                </label>
                <select id="category-filter" class="form-select shadow-sm">
                  <option value="">All Categories</option>
                  <% @available_products.includes(:category).map(&:category).uniq.each do |category| %>
                    <option value="<%= category.name %>"><%= category.name %></option>
                  <% end %>
                </select>
              </div>
              <div class="col-lg-4">
                <label class="form-label text-dark fw-semibold mb-2">
                  <i class="ri-settings-3-line me-1 text-primary"></i>Quick Actions
                </label>
                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-primary flex-fill shadow-sm" onclick="selectAllProducts()">
                    <i class="ri-checkbox-multiple-line me-1"></i>Select All
                  </button>
                  <button type="button" class="btn btn-outline-secondary flex-fill shadow-sm" onclick="clearAllProducts()">
                    <i class="ri-checkbox-blank-line me-1"></i>Clear All
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Enhanced Product Grid -->
          <div class="products-grid-container p-4">
            <div class="row g-4" id="products-grid">
            <% @available_products.each do |product| %>
              <% available_qty = @inventory_data[product.id][:available] %>
              <% current_stock = available_qty.to_i %>
              <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12 product-card" data-product-name="<%= product.name.downcase %>" data-product-sku="<%= product.sku.downcase %>" data-category="<%= @inventory_data[product.id][:category] %>" data-price="<%= product.price || 0 %>" data-product-id="<%= product.id %>">
                <div class="card h-100 border-0 shadow-sm hover-lift beautiful-product-card" id="product-card-<%= product.id %>">

                  <!-- Enhanced Product Image - Matching Booking Page -->
                  <div class="position-relative product-image-wrapper">
                    <% if product.main_image_url.present? %>
                      <img src="<%= product.main_image_url %>" class="card-img-top product-image" style="height: 220px; object-fit: cover;" alt="<%= product.name %>">
                    <% elsif product.images_attached? && product.images.any? %>
                      <%= image_tag product.images.first, class: "card-img-top product-image", style: "height: 220px; object-fit: cover;" %>
                    <% else %>
                      <div class="card-img-top product-placeholder d-flex align-items-center justify-content-center" style="height: 220px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="text-center text-white">
                          <div class="product-icon-wrapper mb-2">
                            <i class="ri-box-3-line" style="font-size: 3rem; opacity: 0.8;"></i>
                          </div>
                          <div class="fw-semibold fs-6 opacity-75"><%= product.category&.name || 'Product' %></div>
                        </div>
                      </div>
                    <% end %>

                    <!-- Gradient overlay for better text readability -->
                    <div class="product-gradient-overlay"></div>

                    <!-- Beautiful Selection Overlay -->
                    <div class="position-absolute top-0 start-0 w-100 h-100 selection-overlay d-flex align-items-center justify-content-center" style="background: rgba(13, 110, 253, 0.85); opacity: 0; transition: all 0.3s ease;">
                      <div class="text-white text-center">
                        <div class="mb-2">
                          <i class="ri-checkbox-circle-fill" style="font-size: 3rem;"></i>
                        </div>
                        <div class="fw-bold fs-5">SELECTED</div>
                      </div>
                    </div>

                    <!-- Beautiful Stock Badge -->
                    <% if current_stock == 0 %>
                      <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge bg-danger shadow-sm" style="font-size: 0.75rem; border-radius: 0.5rem;">
                          <i class="ri-close-circle-fill me-1"></i>Out of Stock
                        </span>
                      </div>
                    <% elsif current_stock < 20 %>
                      <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge bg-warning text-dark shadow-sm" style="font-size: 0.75rem; border-radius: 0.5rem;">
                          <i class="ri-error-warning-fill me-1"></i><%= current_stock %> Available
                        </span>
                      </div>
                    <% else %>
                      <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge bg-success shadow-sm" style="font-size: 0.75rem; border-radius: 0.5rem;">
                          <i class="ri-check-circle-fill me-1"></i><%= current_stock %> Available
                        </span>
                      </div>
                    <% end %>

                    <!-- Beautiful Price Badge -->
                    <% if product.price && product.price > 0 %>
                      <div class="position-absolute bottom-0 start-0 m-3">
                        <span class="badge bg-dark shadow-sm" style="font-size: 0.75rem; border-radius: 0.5rem;">
                          <i class="ri-price-tag-3-fill me-1"></i>₹<%= number_with_delimiter(product.price) %>
                        </span>
                      </div>
                    <% end %>

                    <!-- Beautiful Selection Checkbox -->
                    <div class="position-absolute top-0 start-0 m-3">
                      <div class="form-check">
                        <input class="form-check-input product-checkbox shadow-sm" type="checkbox" id="select-<%= product.id %>" onchange="toggleProductAllocation(<%= product.id %>)" style="width: 1.25rem; height: 1.25rem; border: 2px solid #fff;">
                      </div>
                    </div>
                  </div>

                  <!-- Enhanced Product Details -->
                  <div class="card-body d-flex flex-column p-4">
                    <!-- Category Badge -->
                    <div class="mb-2">
                      <small class="badge bg-light text-dark border">
                        <%= @inventory_data[product.id][:category] || 'Uncategorized' %>
                      </small>
                    </div>

                    <!-- Product Name -->
                    <h6 class="card-title mb-3 fw-bold" style="line-height: 1.3;">
                      <label for="select-<%= product.id %>" class="cursor-pointer text-decoration-none text-dark">
                        <%= product.name %>
                      </label>
                    </h6>

                    <!-- SKU with Enhanced Styling -->
                    <div class="mb-3 text-muted small">
                      <i class="ri-barcode-line me-1"></i>
                      <span>SKU: <%= product.sku %></span>
                    </div>

                    <!-- Enhanced Stock and Price Info with Modern Grid -->
                    <div class="row g-2 mb-3 small">
                      <div class="col-6">
                        <div class="d-flex align-items-center bg-light rounded p-2">
                          <i class="ri-database-2-line text-success me-2"></i>
                          <div>
                            <div class="fw-semibold text-dark"><%= available_qty %> <%= @inventory_data[product.id][:unit] %></div>
                            <div class="text-muted" style="font-size: 0.7rem;">Available</div>
                          </div>
                        </div>
                      </div>
                      <% if product.price && product.price > 0 %>
                        <div class="col-6">
                          <div class="d-flex align-items-center bg-light rounded p-2">
                            <i class="ri-money-rupee-circle-line text-primary me-2"></i>
                            <div>
                              <div class="fw-semibold text-primary">₹<%= number_with_delimiter(product.price) %></div>
                              <div class="text-muted" style="font-size: 0.7rem;">per <%= @inventory_data[product.id][:unit] %></div>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    </div>

                    <!-- Beautiful Allocation Controls -->
                    <div id="allocation-controls-<%= product.id %>" class="allocation-controls mt-auto" style="display: none; opacity: 0; transform: translateY(-10px); transition: all 0.3s ease;">
                      <div class="border-top pt-3">
                        <div class="bg-primary text-white rounded p-3 mb-3">
                          <div class="d-flex align-items-center mb-2">
                            <i class="ri-settings-4-line me-2"></i>
                            <h6 class="mb-0 text-white">Allocation Settings</h6>
                          </div>
                        </div>

                        <div class="mb-3">
                          <label class="form-label small fw-semibold">Quantity to Transfer</label>
                          <div class="input-group">
                            <%= number_field_tag "inventory_allocations[#{product.id}][quantity]",
                                nil,
                                class: "form-control",
                                placeholder: "Enter quantity",
                                min: 0,
                                max: available_qty,
                                step: 0.01,
                                id: "qty-#{product.id}",
                                onchange: "updateAllocation(#{product.id}, this.value, #{available_qty})" %>
                            <button type="button" class="btn btn-outline-primary" onclick="setMaxQuantity(<%= product.id %>, <%= available_qty %>)" title="Set Maximum">
                              <i class="ri-upload-line"></i>
                            </button>
                          </div>
                          <%= hidden_field_tag "inventory_allocations[#{product.id}][product_name]", product.name %>
                          <%= hidden_field_tag "inventory_allocations[#{product.id}][unit]", @inventory_data[product.id][:unit] %>
                        </div>

                        <div class="row g-2 small">
                          <div class="col-6" id="remaining-<%= product.id %>">
                            <div class="bg-light rounded p-2 text-center">
                              <i class="ri-database-2-line text-info mb-1"></i>
                              <div class="fw-semibold text-dark">Remaining</div>
                              <div class="text-muted">
                                <span id="remaining-qty-<%= product.id %>"><%= available_qty %></span>
                                <%= @inventory_data[product.id][:unit] %>
                              </div>
                            </div>
                          </div>
                          <% if product.price && product.price > 0 %>
                            <div class="col-6" id="value-<%= product.id %>">
                              <div class="bg-light rounded p-2 text-center">
                                <i class="ri-money-rupee-circle-line text-success mb-1"></i>
                                <div class="fw-semibold text-dark">Value</div>
                                <div class="text-success fw-semibold">
                                  ₹<span id="transfer-value-<%= product.id %>">0.00</span>
                                </div>
                              </div>
                            </div>
                          <% end %>
                        </div>

                        <div class="alert alert-danger mt-2" id="error-<%= product.id %>" style="display: none; padding: 0.5rem;">
                          <i class="ri-error-warning-line me-1"></i>
                          <small>Allocation cannot exceed available quantity</small>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- No Products Found Message -->
          <div id="no-products-message" class="text-center py-4" style="display: none;">
            <i class="ri-search-line text-muted" style="font-size: 2rem;"></i>
            <p class="text-muted mt-2">No products found matching your search criteria</p>
          </div>

          <div class="alert alert-info mx-4 mb-4">
            <i class="ri-information-line me-2"></i>
            <strong>Note:</strong> Products will be transferred from central inventory to this store immediately upon creation.
            Remaining quantities will stay in central inventory for future allocations.
          </div>
        <% else %>
          <div class="alert alert-warning m-4">
            <i class="ri-alert-line me-2"></i>
            <strong>No Products Available:</strong> There are no products with available inventory in central storage to allocate to this store.
            You can add products later through the inventory transfer system.
          </div>
        <% end %>
          </div>
        </div>
      </div>

      <!-- Inventory Summary -->
      <% if @available_products&.any? %>
      <div class="inventory-summary-section">
        <div class="row">
          <div class="col-lg-8">
            <!-- Selected products will show in the main grid above -->
          </div>

          <div class="col-lg-4">
            <div class="card border-0 shadow-lg modern-summary-card">
              <div class="card-header text-white border-0 p-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="d-flex align-items-center">
                  <div class="summary-icon-wrapper me-3">
                    <i class="ri-shopping-cart-2-line" style="font-size: 2rem;"></i>
                  </div>
                  <div>
                    <h5 class="card-title mb-1 fw-bold">Allocation Summary</h5>
                    <small class="text-white-75">Track your selections</small>
                  </div>
                </div>
              </div>

              <div class="card-body p-0">
                <!-- Enhanced Stats Row -->
                <div class="summary-stats p-4">
                  <div class="row g-3">
                    <div class="col-6">
                      <div class="stat-card text-center p-3 rounded" style="background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);">
                        <div class="stat-icon mb-2">
                          <i class="ri-checkbox-multiple-line text-primary" style="font-size: 2rem;"></i>
                        </div>
                        <div class="stat-value fw-bold fs-3 text-primary" id="selected-count">0</div>
                        <small class="text-muted fw-medium">Selected Items</small>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="stat-card text-center p-3 rounded" style="background: linear-gradient(135deg, #e8f5e8 0%, #f1f8e9 100%);">
                        <div class="stat-icon mb-2">
                          <i class="ri-money-rupee-circle-line text-success" style="font-size: 2rem;"></i>
                        </div>
                        <div class="stat-value fw-bold fs-3 text-success" id="total-value">₹0</div>
                        <small class="text-muted fw-medium">Total Value</small>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Enhanced Selected Products List -->
                <div class="px-4 pb-3">
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="mb-0 text-dark fw-bold">
                      <i class="ri-list-check me-2 text-primary"></i>Selected Products
                    </h6>
                    <span class="badge bg-light text-dark" id="selected-badge">0 items</span>
                  </div>

                  <div id="selected-products-list" class="selected-products-container" style="max-height: 350px; overflow-y: auto;">
                    <div class="empty-selection text-center py-5">
                      <div class="empty-icon mb-3">
                        <i class="ri-shopping-cart-line text-primary" style="font-size: 4rem; opacity: 0.3;"></i>
                      </div>
                      <h6 class="text-muted mb-2 fw-semibold">No Products Selected</h6>
                      <p class="text-muted mb-0 small">Start by selecting products from the grid above</p>
                      <div class="mt-3">
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="optimizeAllocation()">
                          <i class="ri-magic-line me-1"></i>Auto Select
                        </button>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Enhanced Action Buttons -->
                <div class="card-footer bg-gradient border-top-0 p-4" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                  <div class="row g-2">
                    <div class="col-12">
                      <button type="button" class="btn btn-primary w-100 shadow-sm" onclick="optimizeAllocation()">
                        <i class="ri-magic-line me-2"></i>Smart Auto-Select
                      </button>
                    </div>
                    <div class="col-6">
                      <button type="button" class="btn btn-outline-secondary w-100 btn-sm" onclick="selectAllProducts()">
                        <i class="ri-checkbox-multiple-line me-1"></i>Select All
                      </button>
                    </div>
                    <div class="col-6">
                      <button type="button" class="btn btn-outline-danger w-100 btn-sm" onclick="clearAllProducts()">
                        <i class="ri-close-circle-line me-1"></i>Clear All
                      </button>
                    </div>
                  </div>

                  <!-- Legacy Summary for Backward Compatibility -->
                  <div class="mt-3" id="allocation-summary" style="display: none;">
                    <small class="text-muted">No products allocated yet</small>
                  </div>
                </div>
              </div>
            </div>

            <!-- Enhanced Quick Help Card -->
            <div class="card border-0 shadow-sm mt-3 help-card">
              <div class="card-header bg-light border-0 py-3">
                <h6 class="mb-0 text-dark fw-bold">
                  <i class="ri-lightbulb-line text-warning me-2"></i>Quick Guide
                </h6>
              </div>
              <div class="card-body p-3">
                <div class="help-steps">
                  <div class="help-step mb-3 p-2 rounded" style="background: rgba(102, 126, 234, 0.1);">
                    <div class="d-flex align-items-center">
                      <div class="step-number me-3">
                        <span class="badge bg-primary rounded-circle" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;">1</span>
                      </div>
                      <div class="step-content">
                        <div class="fw-semibold text-dark small">Select Products</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Click checkboxes to choose items</div>
                      </div>
                    </div>
                  </div>

                  <div class="help-step mb-3 p-2 rounded" style="background: rgba(40, 167, 69, 0.1);">
                    <div class="d-flex align-items-center">
                      <div class="step-number me-3">
                        <span class="badge bg-success rounded-circle" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;">2</span>
                      </div>
                      <div class="step-content">
                        <div class="fw-semibold text-dark small">Set Quantities</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Enter transfer amounts</div>
                      </div>
                    </div>
                  </div>

                  <div class="help-step p-2 rounded" style="background: rgba(255, 193, 7, 0.1);">
                    <div class="d-flex align-items-center">
                      <div class="step-number me-3">
                        <span class="badge bg-warning text-dark rounded-circle" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;">3</span>
                      </div>
                      <div class="step-content">
                        <div class="fw-semibold text-dark small">Create Store</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Products transfer instantly</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% end %>

        </div> <!-- End inventory-allocation-wrapper -->
      <% end %>
      </div> <!-- End card-body for inventory allocation -->
      </div> <!-- End card for inventory allocation -->
    </div> <!-- End inventory-allocation-section -->

    <!-- Submit Button Section -->
    <div class="text-center mt-4 mb-4">
      <%= form.submit store.new_record? ? "Create Store" : "Update Store", class: "btn btn-success btn-lg px-5 py-3" %>
    </div>

  </div> <!-- End store-creation-form container -->

  <script>
    // Form validation function
    function validateForm() {
      // Validate store information
      const requiredFields = ['name', 'address', 'city', 'state', 'pincode'];
      let isValid = true;

      requiredFields.forEach(field => {
        const input = document.querySelector(`input[name="store[${field}]"], textarea[name="store[${field}]"], select[name="store[${field}]"]`);
        if (input && !input.value.trim()) {
          input.classList.add('is-invalid');
          isValid = false;
        } else if (input) {
          input.classList.remove('is-invalid');
        }
      });

      // Validate admin information if admin creation is enabled
      const createAdmin = document.querySelector('input[name="store[create_admin_user]"]');
      if (createAdmin && createAdmin.checked) {
        const adminFields = ['admin_username', 'admin_password'];
        adminFields.forEach(field => {
          const input = document.querySelector(`input[name="store[${field}]"]`);
          if (input && !input.value.trim()) {
            input.classList.add('is-invalid');
            isValid = false;
          } else if (input) {
            input.classList.remove('is-invalid');
          }
        });
      }

      if (!isValid) {
        alert('Please fill in all required fields.');
        return false;
      }
      return true;
    }

    function toggleAdminSection() {
      const checkbox = document.querySelector('input[name="store[create_admin_user]"]');
      const section = document.getElementById('admin-section');
      const adminFields = ['admin_username', 'admin_password'];

      if (checkbox.checked) {
        section.style.display = 'block';
        adminFields.forEach(fieldId => {
          const field = document.getElementById(fieldId);
          if (field) field.required = true;
        });
      } else {
        section.style.display = 'none';
        adminFields.forEach(fieldId => {
          const field = document.getElementById(fieldId);
          if (field) field.required = false;
        });
      }
    }

    function updateAllocation(productId, allocatedQty, availableQty) {
      const remaining = availableQty - parseFloat(allocatedQty || 0);
      const remainingSpan = document.getElementById(`remaining-qty-${productId}`);
      const errorDiv = document.getElementById(`error-${productId}`);
      const input = document.querySelector(`input[name="inventory_allocations[${productId}][quantity]"]`);
      const transferValueSpan = document.getElementById(`transfer-value-${productId}`);
      const productCard = document.getElementById(`product-card-${productId}`);

      if (remaining < 0) {
        errorDiv.style.display = 'block';
        input.classList.add('is-invalid');
        remainingSpan.textContent = availableQty;
      } else {
        errorDiv.style.display = 'none';
        input.classList.remove('is-invalid');
        remainingSpan.textContent = remaining.toFixed(2);
      }

      // Update transfer value if price is available
      if (transferValueSpan && productCard) {
        const pricePerUnit = parseFloat(productCard.dataset.price || 0);
        const transferValue = (parseFloat(allocatedQty || 0) * pricePerUnit);
        transferValueSpan.textContent = transferValue.toFixed(2);
        console.log(`Product ${productId}: Qty=${allocatedQty}, Price=${pricePerUnit}, Value=${transferValue}`);
      }

      // Update visual selection if quantity > 0
      const checkbox = document.getElementById(`select-${productId}`);
      if (parseFloat(allocatedQty || 0) > 0) {
        if (!checkbox.checked) {
          checkbox.checked = true;
          toggleProductAllocation(productId);
        }
      }

      updateAllocationSummary();
    }

    function updateAllocationSummary() {
      const allocations = [];
      let totalValue = 0;
      let selectedCount = 0;

      // Update sidebar stats
      const selectedCountEl = document.getElementById('selected-count');
      const totalValueEl = document.getElementById('total-value');
      const selectedBadge = document.getElementById('selected-badge');
      const selectedProductsList = document.getElementById('selected-products-list');

      // Get all quantity inputs and process them
      document.querySelectorAll('input[name*="inventory_allocations"][name*="[quantity]"]').forEach(input => {
        const qty = parseFloat(input.value || 0);
        if (qty > 0) {
          selectedCount++;
          const productId = input.name.match(/\[(\d+)\]/)[1];
          const productNameInput = document.querySelector(`input[name="inventory_allocations[${productId}][product_name]"]`);
          const unitInput = document.querySelector(`input[name="inventory_allocations[${productId}][unit]"]`);

          if (productNameInput && unitInput) {
            const productName = productNameInput.value;
            const unit = unitInput.value;

            // Get product price from data attribute
            const productCard = document.getElementById(`product-card-${productId}`);
            const pricePerUnit = parseFloat(productCard?.dataset?.price || 0);
            const itemValue = qty * pricePerUnit;
            totalValue += itemValue;

            console.log(`Summary - Product ${productId}: ${productName}, Qty: ${qty}, Price: ${pricePerUnit}, Value: ${itemValue}`);

            allocations.push({
              name: productName,
              qty: qty,
              unit: unit,
              value: itemValue,
              id: productId
            });
          }
        }
      });

      console.log(`Total selected: ${selectedCount}, Total value: ${totalValue}`);

      // Update sidebar statistics
      if (selectedCountEl) selectedCountEl.textContent = selectedCount;
      if (totalValueEl) totalValueEl.textContent = `₹${totalValue.toLocaleString('en-IN', {minimumFractionDigits: 0, maximumFractionDigits: 0})}`;
      if (selectedBadge) selectedBadge.textContent = `${selectedCount} item${selectedCount !== 1 ? 's' : ''}`;

      // Update selected products list in sidebar
      if (selectedProductsList) {
        if (allocations.length > 0) {
          selectedProductsList.innerHTML = allocations.map(item => `
            <div class="selected-product-item mb-2 p-3 rounded shadow-sm border-0" style="background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%); border-left: 3px solid #667eea !important;">
              <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                  <div class="fw-bold text-dark text-truncate mb-1" style="font-size: 0.85rem;">${item.name}</div>
                  <div class="d-flex align-items-center">
                    <span class="badge bg-light text-primary me-2" style="font-size: 0.7rem;">${item.qty} ${item.unit}</span>
                    <small class="text-muted">Quantity</small>
                  </div>
                </div>
                <div class="text-end ms-2">
                  <div class="fw-bold text-success" style="font-size: 0.9rem;">₹${item.value.toLocaleString('en-IN', {minimumFractionDigits: 0, maximumFractionDigits: 0})}</div>
                  <small class="text-muted">Value</small>
                </div>
              </div>
            </div>
          `).join('');
        } else {
          selectedProductsList.innerHTML = `
            <div class="empty-selection text-center py-5">
              <div class="empty-icon mb-3">
                <i class="ri-shopping-cart-line text-primary" style="font-size: 4rem; opacity: 0.3;"></i>
              </div>
              <h6 class="text-muted mb-2 fw-semibold">No Products Selected</h6>
              <p class="text-muted mb-0 small">Start by selecting products from the grid above</p>
              <div class="mt-3">
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="optimizeAllocation()">
                  <i class="ri-magic-line me-1"></i>Auto Select
                </button>
              </div>
            </div>
          `;
        }
      }

      // Also update the old summary for backward compatibility
      const summaryDiv = document.getElementById('allocation-summary');
      if (summaryDiv) {
        if (allocations.length > 0) {
          summaryDiv.innerHTML = `
            <strong>Selected Products (${selectedCount}):</strong><br>
            ${allocations.map(item => `${item.name}: ${item.qty} ${item.unit} (₹${item.value.toFixed(2)})`).join('<br>')}
            <hr>
            <strong>Total Transfer Value: ₹${totalValue.toFixed(2)}</strong>
          `;
        } else {
          summaryDiv.innerHTML = 'No products allocated yet';
        }
      }
    }


    function optimizeAllocation() {
      // Smart allocation: Select products with available stock, allocate 30% of available
      clearAllProducts();

      setTimeout(() => {
        document.querySelectorAll('.product-checkbox').forEach(checkbox => {
          const productId = checkbox.id.replace('select-', '');
          const qtyInput = document.getElementById(`qty-${productId}`);
          const maxQty = parseFloat(qtyInput?.max || 0);

          // Only select if available quantity > 5
          if (maxQty > 5) {
            checkbox.checked = true;
            toggleProductAllocation(productId);

            // Wait for controls to be shown then set quantity
            setTimeout(() => {
              // Allocate 30% of available stock (rounded)
              const smartQty = Math.max(1, Math.round(maxQty * 0.3));
              qtyInput.value = smartQty;
              updateAllocation(productId, smartQty, maxQty);
            }, 200);
          }
        });

        // Final update after all selections
        setTimeout(() => {
          updateAllocationSummary();
        }, 1000);
      }, 100);
    }

    // Enhanced inventory allocation functions with beautiful visual effects
    function toggleProductAllocation(productId) {
      const checkbox = document.getElementById(`select-${productId}`);
      const controls = document.getElementById(`allocation-controls-${productId}`);
      const card = document.getElementById(`product-card-${productId}`);
      const overlay = card.querySelector('.selection-overlay');

      if (checkbox.checked) {
        // Add beautiful visual effects
        card.classList.add('selected-card');

        // Show overlay with smooth animation
        if (overlay) {
          overlay.style.opacity = '1';
          overlay.style.transform = 'scale(1)';
        }

        // Show allocation controls with smooth transition
        if (controls) {
          controls.style.display = 'block';
          setTimeout(() => {
            controls.style.opacity = '1';
            controls.style.transform = 'translateY(0)';
          }, 100);
        }

      } else {
        // Remove visual effects smoothly
        card.classList.remove('selected-card');

        // Hide overlay smoothly
        if (overlay) {
          overlay.style.opacity = '0';
          overlay.style.transform = 'scale(0.95)';
        }

        // Hide allocation controls with smooth transition
        if (controls) {
          controls.style.opacity = '0';
          controls.style.transform = 'translateY(-15px)';
          setTimeout(() => {
            controls.style.display = 'none';
          }, 300);
        }

        // Clear the quantity input and reset values
        const qtyInput = document.getElementById(`qty-${productId}`);
        if (qtyInput) {
          qtyInput.value = '';
          // Reset remaining quantity
          const remainingSpan = document.getElementById(`remaining-qty-${productId}`);
          const maxQty = parseFloat(qtyInput.max);
          if (remainingSpan) {
            remainingSpan.textContent = maxQty;
          }
          // Reset transfer value
          const transferValueSpan = document.getElementById(`transfer-value-${productId}`);
          if (transferValueSpan) {
            transferValueSpan.textContent = '0.00';
          }
        }
      }

      updateAllocationSummary();
      updateNextButtonState();
    }

    function setMaxQuantity(productId, maxQty) {
      const qtyInput = document.getElementById(`qty-${productId}`);
      const checkbox = document.getElementById(`select-${productId}`);

      if (qtyInput) {
        qtyInput.value = maxQty;

        // Ensure product is selected
        if (!checkbox.checked) {
          checkbox.checked = true;
          toggleProductAllocation(productId);
        }

        updateAllocation(productId, maxQty, maxQty);
      }
    }

    function selectAllProducts() {
      document.querySelectorAll('.product-checkbox:not(:checked)').forEach(checkbox => {
        checkbox.checked = true;
        const productId = checkbox.id.replace('select-', '');
        toggleProductAllocation(productId);

        // Set a default quantity (10% of available or minimum 1)
        setTimeout(() => {
          const qtyInput = document.getElementById(`qty-${productId}`);
          if (qtyInput) {
            const maxQty = parseFloat(qtyInput.max);
            const defaultQty = Math.max(1, Math.round(maxQty * 0.1));
            qtyInput.value = defaultQty;
            updateAllocation(productId, defaultQty, maxQty);
          }
        }, 100);
      });
    }

    function clearAllProducts() {
      document.querySelectorAll('.product-checkbox:checked').forEach(checkbox => {
        checkbox.checked = false;
        const productId = checkbox.id.replace('select-', '');
        toggleProductAllocation(productId);
      });
      updateAllocationSummary();
    }

    function filterProducts() {
      const searchTerm = document.getElementById('product-search').value.toLowerCase();
      const categoryFilter = document.getElementById('category-filter').value;
      const productCards = document.querySelectorAll('.product-card');
      let visibleCount = 0;

      productCards.forEach(card => {
        const productName = card.dataset.productName;
        const productSku = card.dataset.productSku;
        const category = card.dataset.category;

        const matchesSearch = searchTerm === '' ||
                            productName.includes(searchTerm) ||
                            productSku.includes(searchTerm);
        const matchesCategory = categoryFilter === '' || category === categoryFilter;

        if (matchesSearch && matchesCategory) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      // Show/hide no products message
      const noProductsMessage = document.getElementById('no-products-message');
      if (visibleCount === 0) {
        noProductsMessage.style.display = 'block';
      } else {
        noProductsMessage.style.display = 'none';
      }
    }

    // Load products for a specific store (for editing existing stores)
    function loadStoreProducts(storeId) {
      if (!storeId) return;

      fetch(`/admin/stores/get_product_availability?store_id=${storeId}`, {
        method: 'GET',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          updateProductCards(data.products);
          updateSidebarStats(data.summary);
        } else {
          console.error('Error loading products:', data.error);
        }
      })
      .catch(error => {
        console.error('Error fetching products:', error);
      });
    }

    // Update product cards with fresh inventory data
    function updateProductCards(products) {
      products.forEach(product => {
        const card = document.getElementById(`product-card-${product.id}`);
        if (card) {
          const availableSpan = card.querySelector('.text-success');
          if (availableSpan) {
            availableSpan.innerHTML = `<i class="ri-package-line me-1"></i>${product.central_available} ${product.unit}`;
          }
        }
      });
    }

    // Refresh all inventory data
    function refreshInventoryData() {
      const loadingOverlay = document.createElement('div');
      loadingOverlay.className = 'position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center';
      loadingOverlay.style.backgroundColor = 'rgba(0,0,0,0.5)';
      loadingOverlay.style.zIndex = '9999';
      loadingOverlay.innerHTML = `
        <div class="bg-white p-4 rounded shadow">
          <div class="text-center">
            <div class="spinner-border text-primary mb-2" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
            <div>Refreshing inventory data...</div>
          </div>
        </div>
      `;
      document.body.appendChild(loadingOverlay);

      // Simulate refresh (in real implementation, this would fetch fresh data)
      setTimeout(() => {
        document.body.removeChild(loadingOverlay);
        updateAllocationSummary(); // Refresh the summary
      }, 1500);
    }

    // Two-Step Navigation Functions
    let currentStep = 1;

    function goToNextStep() {
      if (currentStep === 1) {
        // Check if any products are selected
        const selectedCount = document.querySelectorAll('input[name*="inventory_allocations"][name*="[quantity]"]').length;
        const hasSelections = Array.from(document.querySelectorAll('input[name*="inventory_allocations"][name*="[quantity]"]')).some(input => parseFloat(input.value || 0) > 0);

        if (!hasSelections) {
          showNotification('Please select at least one product with a quantity before proceeding to review.', 'warning');
          return;
        }

        // Add enhanced loading state with progress
        const nextBtn = document.getElementById('nextStepBtn');
        nextBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Preparing Review...';
        nextBtn.disabled = true;

        // Add progress indicator
        const progressIndicator = document.createElement('div');
        progressIndicator.className = 'progress mt-2';
        progressIndicator.style.height = '3px';
        progressIndicator.innerHTML = `
          <div class="progress-bar bg-success progress-bar-striped progress-bar-animated"
               style="width: 0%; transition: width 0.8s ease-in-out;"></div>
        `;
        nextBtn.parentNode.appendChild(progressIndicator);

        // Animate progress bar
        setTimeout(() => {
          const bar = progressIndicator.querySelector('.progress-bar');
          bar.style.width = '100%';
        }, 100);

        setTimeout(() => {
          // Clean up progress indicator
          const existingProgress = nextBtn.parentNode.querySelector('.progress');
          if (existingProgress) {
            existingProgress.remove();
          }

          // Move to step 2 with animation
          currentStep = 2;
          const step1 = document.getElementById('step-1-content');
          const step2 = document.getElementById('step-2-content');

          // Fade out step 1 with enhanced animation
          step1.style.opacity = '0';
          step1.style.transform = 'translateX(-20px) scale(0.98)';

          setTimeout(() => {
            step1.style.display = 'none';
            step2.style.display = 'block';
            step2.style.opacity = '0';
            step2.style.transform = 'translateX(20px) scale(0.98)';

            // Fade in step 2 with bounce effect
            setTimeout(() => {
              step2.style.opacity = '1';
              step2.style.transform = 'translateX(0) scale(1)';
            }, 50);
          }, 300);

          // Update step indicators with animation
          updateStepIndicators();

          // Update navigation buttons with loading states
          const prevBtn = document.getElementById('prevStepBtn');
          prevBtn.style.display = 'inline-block';
          prevBtn.innerHTML = '<i class="ri-arrow-left-line me-1"></i>Back to Selection';

          nextBtn.style.display = 'none';
          nextBtn.innerHTML = 'Next: Review <i class="ri-arrow-right-line ms-1"></i>';
          nextBtn.disabled = false;

          // Update progress with success state
          updateProgressBar();

          // Populate review section with loading animation
          populateReviewSection();

          // Enhanced success notification
          showNotification('✨ Review your selection below and confirm to create store', 'success');
        }, 800);
      }
    }

    function goToPreviousStep() {
      if (currentStep === 2) {
        // Move back to step 1 with animation
        currentStep = 1;
        const step1 = document.getElementById('step-1-content');
        const step2 = document.getElementById('step-2-content');

        // Fade out step 2
        step2.style.opacity = '0';
        step2.style.transform = 'translateX(20px)';

        setTimeout(() => {
          step2.style.display = 'none';
          step1.style.display = 'block';
          step1.style.opacity = '0';
          step1.style.transform = 'translateX(-20px)';

          // Fade in step 1
          setTimeout(() => {
            step1.style.opacity = '1';
            step1.style.transform = 'translateX(0)';
          }, 50);
        }, 300);

        // Update step indicators with animation
        updateStepIndicators();

        // Update navigation buttons
        document.getElementById('prevStepBtn').style.display = 'none';
        document.getElementById('nextStepBtn').style.display = 'inline-block';

        // Update progress
        updateProgressBar();

        // Update next button state
        updateNextButtonState();

        showNotification('Continue selecting products', 'info');
      }
    }

    function updateStepIndicators() {
      const step1 = document.getElementById('step-1-indicator');
      const step2 = document.getElementById('step-2-indicator');
      const connector = document.getElementById('connector-progress');

      if (currentStep === 1) {
        step1.classList.remove('completed');
        step1.classList.add('active');
        step2.classList.remove('active');
        connector.style.width = '0%';
      } else if (currentStep === 2) {
        step1.classList.remove('active');
        step1.classList.add('completed');
        step2.classList.add('active');
        connector.style.width = '100%';
      }
    }

    function updateProgressBar() {
      const progressBar = document.getElementById('step-progress-bar');
      const progressText = document.getElementById('step-progress-text');

      if (currentStep === 1) {
        progressBar.style.width = '50%';
        progressText.textContent = 'Step 1 of 2';
      } else if (currentStep === 2) {
        progressBar.style.width = '100%';
        progressText.textContent = 'Step 2 of 2 - Almost done!';
      }
    }

    function updateNextButtonState() {
      const hasSelections = Array.from(document.querySelectorAll('input[name*="inventory_allocations"][name*="[quantity]"]')).some(input => parseFloat(input.value || 0) > 0);
      const nextBtn = document.getElementById('nextStepBtn');

      if (hasSelections) {
        nextBtn.disabled = false;
        nextBtn.innerHTML = 'Next: Review <i class="ri-arrow-right-line ms-1"></i>';
      } else {
        nextBtn.disabled = true;
        nextBtn.innerHTML = 'Select Products First <i class="ri-arrow-right-line ms-1"></i>';
      }
    }

    function populateReviewSection() {
      const reviewContainer = document.getElementById('selected-products-review');
      const allocations = [];

      // Get all selected products
      document.querySelectorAll('input[name*="inventory_allocations"][name*="[quantity]"]').forEach(input => {
        const qty = parseFloat(input.value || 0);
        if (qty > 0) {
          const productId = input.name.match(/\[(\d+)\]/)[1];
          const productNameInput = document.querySelector(`input[name="inventory_allocations[${productId}][product_name]"]`);
          const unitInput = document.querySelector(`input[name="inventory_allocations[${productId}][unit]"]`);
          const productCard = document.getElementById(`product-card-${productId}`);

          if (productNameInput && unitInput && productCard) {
            const productName = productNameInput.value;
            const unit = unitInput.value;
            const pricePerUnit = parseFloat(productCard.dataset.price || 0);
            const itemValue = qty * pricePerUnit;

            allocations.push({
              id: productId,
              name: productName,
              qty: qty,
              unit: unit,
              price: pricePerUnit,
              value: itemValue
            });
          }
        }
      });

      if (allocations.length > 0) {
        reviewContainer.innerHTML = allocations.map(item => `
          <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #28a745 !important;">
              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <h6 class="card-title mb-0 fw-bold text-dark">${item.name}</h6>
                  <span class="badge bg-success">Selected</span>
                </div>
                <div class="mb-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted small">Quantity:</span>
                    <span class="fw-bold text-primary">${item.qty} ${item.unit}</span>
                  </div>
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted small">Unit Price:</span>
                    <span class="fw-bold">₹${item.price.toLocaleString('en-IN')}</span>
                  </div>
                  <hr class="my-2">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Total Value:</span>
                    <span class="fw-bold text-success fs-6">₹${item.value.toLocaleString('en-IN', {minimumFractionDigits: 0, maximumFractionDigits: 0})}</span>
                  </div>
                </div>
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="editProduct(${item.id})">
                  <i class="ri-edit-line me-1"></i>Edit Quantity
                </button>
              </div>
            </div>
          </div>
        `).join('');
      } else {
        reviewContainer.innerHTML = `
          <div class="col-12">
            <div class="text-center py-5">
              <i class="ri-shopping-cart-line text-muted mb-3" style="font-size: 4rem; opacity: 0.3;"></i>
              <h6 class="text-muted mb-2">No Products Selected</h6>
              <p class="text-muted mb-3">Go back to Step 1 to select products</p>
              <button type="button" class="btn btn-outline-primary" onclick="goToPreviousStep()">
                <i class="ri-arrow-left-line me-1"></i>Back to Product Selection
              </button>
            </div>
          </div>
        `;
      }

      // Update summary in sidebar
      updateAllocationSummary();
    }

    function editProduct(productId) {
      // Go back to step 1 and highlight the specific product
      goToPreviousStep();

      // Scroll to the product and highlight it
      setTimeout(() => {
        const productCard = document.getElementById(`product-card-${productId}`);
        if (productCard) {
          productCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
          productCard.style.outline = '3px solid #0d6efd';
          setTimeout(() => {
            productCard.style.outline = '';
          }, 3000);
        }
      }, 300);
    }

    // Initialize admin section visibility and add event listeners
    document.addEventListener('DOMContentLoaded', function() {
      toggleAdminSection();

      // Add event listeners for search and filter
      const searchInput = document.getElementById('product-search');
      const categoryFilter = document.getElementById('category-filter');

      if (searchInput) {
        searchInput.addEventListener('input', filterProducts);
      }

      if (categoryFilter) {
        categoryFilter.addEventListener('change', filterProducts);
      }

      // Initialize step state
      updateNextButtonState();

      // Show welcome notification
      setTimeout(() => {
        showNotification('👋 Welcome! Start by selecting products for your new store', 'info');
      }, 500);
    });

    // Enhanced notification system
    function showNotification(message, type = 'info') {
      // Remove existing notifications
      const existingNotifications = document.querySelectorAll('.step-notification');
      existingNotifications.forEach(n => n.remove());

      const notification = document.createElement('div');
      notification.className = `alert alert-${type} step-notification border-0 shadow-sm`;
      notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        min-width: 350px;
        opacity: 0;
        transform: translateX(100px);
        transition: all 0.4s ease-out;
        border-left: 4px solid ${type === 'success' ? '#28a745' : type === 'warning' ? '#ffc107' : '#17a2b8'} !important;
      `;

      const iconMap = {
        success: 'ri-check-double-line',
        warning: 'ri-alert-line',
        info: 'ri-information-line',
        error: 'ri-error-warning-line'
      };

      notification.innerHTML = `
        <div class="d-flex align-items-center">
          <i class="${iconMap[type]} me-2" style="font-size: 1.2rem;"></i>
          <span>${message}</span>
          <button type="button" class="btn-close ms-auto" onclick="this.parentElement.parentElement.remove()"></button>
        </div>
      `;

      document.body.appendChild(notification);

      // Animate in
      setTimeout(() => {
        notification.style.opacity = '1';
        notification.style.transform = 'translateX(0)';
      }, 100);

      // Auto remove after 4 seconds
      setTimeout(() => {
        if (notification.parentElement) {
          notification.style.opacity = '0';
          notification.style.transform = 'translateX(100px)';
          setTimeout(() => {
            if (notification.parentElement) {
              notification.remove();
            }
          }, 400);
        }
      }, 4000);
    }

    // Wizard Navigation Functions
    let currentWizardStep = 1;
    const totalWizardSteps = 3;

    function goToNextWizardStep() {
      if (currentWizardStep < totalWizardSteps) {
        // Validate current step before proceeding
        if (validateCurrentStep()) {
          // Hide current step
          document.getElementById(`wizard-page-${currentWizardStep}`).style.display = 'none';
          document.getElementById(`wizard-step-${currentWizardStep}`).classList.remove('active');
          document.getElementById(`wizard-step-${currentWizardStep}`).classList.add('completed');

          // Show next step
          currentWizardStep++;
          document.getElementById(`wizard-page-${currentWizardStep}`).style.display = 'block';
          document.getElementById(`wizard-step-${currentWizardStep}`).classList.add('active');

          // Update navigation buttons
          updateWizardButtons();

          // Scroll to top
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      }
    }

    function goToPreviousWizardStep() {
      if (currentWizardStep > 1) {
        // Hide current step
        document.getElementById(`wizard-page-${currentWizardStep}`).style.display = 'none';
        document.getElementById(`wizard-step-${currentWizardStep}`).classList.remove('active');

        // Show previous step
        currentWizardStep--;
        document.getElementById(`wizard-page-${currentWizardStep}`).style.display = 'block';
        document.getElementById(`wizard-step-${currentWizardStep}`).classList.remove('completed');
        document.getElementById(`wizard-step-${currentWizardStep}`).classList.add('active');

        // Update navigation buttons
        updateWizardButtons();

        // Scroll to top
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    function updateWizardButtons() {
      const prevBtn = document.getElementById('wizardPrevBtn');
      const nextBtn = document.getElementById('wizardNextBtn');
      const submitBtn = document.getElementById('wizardSubmitBtn');

      // Show/hide previous button
      if (currentWizardStep === 1) {
        prevBtn.style.display = 'none';
      } else {
        prevBtn.style.display = 'block';
      }

      // Update next/submit button
      if (currentWizardStep === totalWizardSteps) {
        nextBtn.style.display = 'none';
        submitBtn.style.display = 'block';
      } else {
        nextBtn.style.display = 'block';
        submitBtn.style.display = 'none';

        // Update button text based on current step
        if (currentWizardStep === 1) {
          nextBtn.innerHTML = 'Next: Admin Setup <i class="ri-arrow-right-line ms-2"></i>';
        } else if (currentWizardStep === 2) {
          nextBtn.innerHTML = 'Next: Inventory Setup <i class="ri-arrow-right-line ms-2"></i>';
        }
      }
    }

    function validateCurrentStep() {
      if (currentWizardStep === 1) {
        // Validate store information
        const requiredFields = ['name', 'address', 'city', 'state', 'pincode'];
        let isValid = true;

        requiredFields.forEach(field => {
          const input = document.querySelector(`input[name="store[${field}]"], textarea[name="store[${field}]"], select[name="store[${field}]"]`);
          if (input && !input.value.trim()) {
            input.classList.add('is-invalid');
            isValid = false;
          } else if (input) {
            input.classList.remove('is-invalid');
          }
        });

        if (!isValid) {
          alert('Please fill in all required store information fields.');
          return false;
        }

      } else if (currentWizardStep === 2) {
        // Validate admin information if admin creation is enabled
        const createAdmin = document.querySelector('input[name="store[create_admin_user]"]').checked;

        if (createAdmin) {
          const adminFields = ['admin_username', 'admin_password'];
          let isValid = true;

          adminFields.forEach(field => {
            const input = document.querySelector(`input[name="store[${field}]"]`);
            if (input && !input.value.trim()) {
              input.classList.add('is-invalid');
              isValid = false;
            } else if (input) {
              input.classList.remove('is-invalid');
            }
          });

          if (!isValid) {
            alert('Please fill in all required admin account fields.');
            return false;
          }
        }
      }

      return true;
    }

    // Initialize wizard on page load
    document.addEventListener('DOMContentLoaded', function() {
      updateWizardButtons();

      // Show first page by default
      document.getElementById('wizard-page-1').style.display = 'block';
    });
  </script>

