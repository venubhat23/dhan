<%= form_with(model: [:admin, store], local: true) do |form| %>
  <% if store.errors.any? %>
    <div class="alert alert-danger alert-dismissible" role="alert">
      <h6 class="alert-heading mb-1">Please fix the following errors:</h6>
      <ul class="mb-0">
        <% store.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <!-- Store Information Section -->
  <div class="card mb-4">
    <div class="card-header">
      <h5 class="card-title mb-0">
        <i class="ri-store-2-line me-2"></i>Store Information
      </h5>
    </div>
    <div class="card-body">
      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">Store Name <span class="text-danger">*</span></label>
          <%= form.text_field :name, class: "form-control", placeholder: "Enter store name", required: true %>
        </div>
        <div class="col-md-6">
          <label class="form-label">Contact Person <span class="text-danger">*</span></label>
          <%= form.text_field :contact_person, class: "form-control", placeholder: "Enter contact person name", required: true %>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">Contact Mobile <span class="text-danger">*</span></label>
          <%= form.text_field :contact_mobile, class: "form-control", placeholder: "Enter 10-digit mobile number", required: true %>
        </div>
        <div class="col-md-6">
          <label class="form-label">Email</label>
          <%= form.email_field :email, class: "form-control", placeholder: "Enter store email (optional)" %>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Address <span class="text-danger">*</span></label>
        <%= form.text_area :address, class: "form-control", rows: 3, placeholder: "Enter complete address", required: true %>
      </div>

      <div class="row mb-3">
        <div class="col-md-4">
          <label class="form-label">City <span class="text-danger">*</span></label>
          <%= form.text_field :city, class: "form-control", placeholder: "Enter city", required: true %>
        </div>
        <div class="col-md-4">
          <label class="form-label">State <span class="text-danger">*</span></label>
          <%= form.text_field :state, class: "form-control", placeholder: "Enter state", required: true %>
        </div>
        <div class="col-md-4">
          <label class="form-label">Pincode <span class="text-danger">*</span></label>
          <%= form.text_field :pincode, class: "form-control", placeholder: "6-digit pincode", required: true %>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">Description</label>
          <%= form.text_area :description, class: "form-control", rows: 3, placeholder: "Enter store description (optional)" %>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <label class="form-label">Status</label>
            <div class="form-check form-switch mt-2">
              <%= form.check_box :status, class: "form-check-input", checked: store.new_record? ? true : store.status %>
              <label class="form-check-label">Active</label>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Inventory Management</label>
            <div class="form-check form-switch mt-2">
              <%= form.check_box :inventory_management_enabled, class: "form-check-input", checked: store.new_record? ? true : store.inventory_management_enabled %>
              <label class="form-check-label">Enable Inventory Management</label>
            </div>
          </div>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">Auto Transfer Threshold</label>
          <%= form.number_field :auto_transfer_threshold, class: "form-control", placeholder: "Minimum stock level", min: 0 %>
          <small class="text-muted">Automatic transfer requests when stock goes below this level</small>
        </div>
        <div class="col-md-6">
          <label class="form-label">GST Number</label>
          <%= form.text_field :gst_no, class: "form-control", placeholder: "Enter GST number (optional)" %>
        </div>
      </div>
    </div>
  </div>

  <% if store.new_record? %>
    <!-- Store Admin Setup Section -->
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="card-title mb-0">
          <i class="ri-user-settings-line me-2"></i>Store Admin Setup
        </h5>
        <div class="form-check form-switch mt-2">
          <%= form.check_box :create_admin_user, class: "form-check-input", checked: true, onchange: "toggleAdminSection()" %>
          <label class="form-check-label">Create Store Admin Account</label>
        </div>
      </div>
      <div class="card-body" id="admin-section">
        <div class="row mb-3">
          <div class="col-md-6">
            <label class="form-label">Username <span class="text-danger">*</span></label>
            <%= form.text_field :admin_username, class: "form-control", placeholder: "admin_username", id: "admin_username" %>
          </div>
          <div class="col-md-6">
            <label class="form-label">Admin Password <span class="text-danger">*</span></label>
            <%= form.password_field :admin_password, class: "form-control", placeholder: "Minimum 6 characters", id: "admin_password" %>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-6">
            <label class="form-label">Admin Email</label>
            <%= form.email_field :admin_email, class: "form-control", placeholder: "Will be auto-generated if empty", id: "admin_email" %>
            <small class="text-muted">Leave empty to auto-generate from username</small>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-6">
            <label class="form-label">First Name <span class="text-danger">*</span></label>
            <%= form.text_field :admin_first_name, class: "form-control", placeholder: "Enter first name", id: "admin_first_name" %>
          </div>
          <div class="col-md-6">
            <label class="form-label">Last Name <span class="text-danger">*</span></label>
            <%= form.text_field :admin_last_name, class: "form-control", placeholder: "Enter last name", id: "admin_last_name" %>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-6">
            <label class="form-label">Mobile Number <span class="text-danger">*</span></label>
            <%= form.text_field :admin_mobile, class: "form-control", placeholder: "10-digit mobile number", id: "admin_mobile" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Initial Inventory Allocation Section -->
    <div class="row">
      <!-- Main Content -->
      <div class="col-lg-8">
        <div class="card mb-4 inventory-allocation-card">
          <div class="card-header bg-gradient-primary text-white">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <h5 class="card-title mb-0">
                  <i class="ri-box-3-line me-2"></i>Initial Inventory Allocation
                </h5>
                <small class="text-white-50">Choose and transfer products from central inventory to this new store</small>
              </div>
              <div class="text-end">
                <button type="button" class="btn btn-light btn-sm me-2" onclick="refreshInventoryData()" title="Refresh Inventory">
                  <i class="ri-refresh-line me-1"></i>Refresh
                </button>
                <button type="button" class="btn btn-outline-light btn-sm" onclick="optimizeAllocation()" title="Smart Auto-Select">
                  <i class="ri-magic-line me-1"></i>Smart Select
                </button>
              </div>
            </div>
          </div>
          <div class="card-body">
        <% if @available_products&.any? %>
          <!-- Enhanced Search and Filter Controls -->
          <div class="inventory-controls bg-light p-4 rounded-3 mb-4">
            <div class="row g-3">
              <div class="col-lg-5">
                <label class="form-label text-muted fw-semibold mb-1">Search Products</label>
                <div class="input-group input-group-lg">
                  <span class="input-group-text bg-white border-end-0">
                    <i class="ri-search-line text-muted"></i>
                  </span>
                  <input type="text" id="product-search" class="form-control border-start-0 ps-0" placeholder="Search by name, SKU, or category...">
                  <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('product-search').value=''; filterProducts();">
                    <i class="ri-close-line"></i>
                  </button>
                </div>
              </div>
              <div class="col-lg-3">
                <label class="form-label text-muted fw-semibold mb-1">Filter by Category</label>
                <select id="category-filter" class="form-select form-select-lg">
                  <option value="">All Categories</option>
                  <% @available_products.includes(:category).map(&:category).uniq.each do |category| %>
                    <option value="<%= category.name %>"><%= category.name %></option>
                  <% end %>
                </select>
              </div>
              <div class="col-lg-4">
                <label class="form-label text-muted fw-semibold mb-1">Quick Actions</label>
                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-primary btn-lg flex-fill" onclick="selectAllProducts()">
                    <i class="ri-checkbox-multiple-line me-1"></i>Select All
                  </button>
                  <button type="button" class="btn btn-outline-secondary btn-lg flex-fill" onclick="clearAllProducts()">
                    <i class="ri-checkbox-blank-line me-1"></i>Clear All
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Enhanced Product Grid -->
          <div class="products-grid-container">
            <div class="row g-4" id="products-grid">
            <% @available_products.each do |product| %>
              <% available_qty = @inventory_data[product.id][:available] %>
              <% current_stock = available_qty.to_i %>
              <div class="col-lg-4 col-md-6 col-sm-12 product-card" data-product-name="<%= product.name.downcase %>" data-product-sku="<%= product.sku.downcase %>" data-category="<%= @inventory_data[product.id][:category] %>" data-price="<%= product.price || 0 %>" data-product-id="<%= product.id %>">
                <div class="card h-100 border-0 shadow-hover modern-product-card" id="product-card-<%= product.id %>">

                  <!-- Enhanced Product Image with Gradient Overlay -->
                  <div class="position-relative product-image-container">
                    <% if product.image_url.present? %>
                      <img src="<%= product.image_url %>" class="card-img-top product-image" style="height: 220px; object-fit: cover;" alt="<%= product.name %>">
                    <% elsif product.respond_to?(:images) && product.images.respond_to?(:attached?) && product.images.attached? && product.images.any? %>
                      <%= image_tag product.images.first, class: "card-img-top product-image", style: "height: 220px; object-fit: cover;" %>
                    <% else %>
                      <div class="card-img-top product-placeholder d-flex align-items-center justify-content-center" style="height: 220px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%, #f093fb 100%);">
                        <div class="text-center text-white">
                          <div class="product-icon-wrapper">
                            <i class="ri-box-3-line product-icon"></i>
                          </div>
                          <div class="mt-3 fw-semibold fs-6"><%= product.category&.name || 'Product' %></div>
                        </div>
                      </div>
                    <% end %>

                    <!-- Gradient overlay for better text readability -->
                    <div class="product-gradient-overlay"></div>

                    <!-- Enhanced Selection Overlay -->
                    <div class="position-absolute top-0 start-0 w-100 h-100 selection-overlay d-flex align-items-center justify-content-center">
                      <div class="text-white text-center selection-content">
                        <div class="selection-icon-wrapper">
                          <i class="ri-checkbox-circle-fill selection-icon"></i>
                        </div>
                        <div class="mt-2 fw-bold fs-5 selection-text">SELECTED</div>
                        <div class="selection-pulse"></div>
                      </div>
                    </div>

                    <!-- Enhanced Stock Badge -->
                    <% if current_stock == 0 %>
                      <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge modern-badge badge-danger">
                          <i class="ri-close-circle-fill me-1"></i>Out of Stock
                        </span>
                      </div>
                    <% elsif current_stock < 20 %>
                      <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge modern-badge badge-warning">
                          <i class="ri-error-warning-fill me-1"></i>Low Stock
                          <span class="badge-count"><%= current_stock %></span>
                        </span>
                      </div>
                    <% else %>
                      <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge modern-badge badge-success">
                          <i class="ri-check-circle-fill me-1"></i><%= current_stock %> Available
                        </span>
                      </div>
                    <% end %>

                    <!-- Enhanced Price Badge -->
                    <% if product.price && product.price > 0 %>
                      <div class="position-absolute bottom-0 start-0 m-3">
                        <span class="badge modern-badge badge-price">
                          <i class="ri-price-tag-3-fill me-1"></i>₹<%= number_with_delimiter(product.price) %>
                        </span>
                      </div>
                    <% end %>

                    <!-- Enhanced Selection Checkbox -->
                    <div class="position-absolute top-0 start-0 m-3">
                      <div class="modern-checkbox">
                        <input class="form-check-input product-checkbox" type="checkbox" id="select-<%= product.id %>" onchange="toggleProductAllocation(<%= product.id %>)">
                        <label for="select-<%= product.id %>" class="checkbox-label">
                          <span class="checkbox-custom">
                            <i class="ri-check-line"></i>
                          </span>
                        </label>
                      </div>
                    </div>
                  </div>

                  <!-- Enhanced Product Details -->
                  <div class="card-body d-flex flex-column p-4">
                    <!-- Category Badge -->
                    <div class="mb-3">
                      <span class="category-badge">
                        <%= @inventory_data[product.id][:category] || 'Uncategorized' %>
                      </span>
                    </div>

                    <!-- Product Name -->
                    <h6 class="card-title mb-3 product-title">
                      <label for="select-<%= product.id %>" class="cursor-pointer text-decoration-none text-dark">
                        <%= product.name %>
                      </label>
                    </h6>

                    <!-- SKU with Enhanced Styling -->
                    <div class="product-sku mb-3">
                      <i class="ri-barcode-line me-2"></i>
                      <span class="sku-text">SKU: <%= product.sku %></span>
                    </div>

                    <!-- Enhanced Stock and Price Info -->
                    <div class="product-info-grid mb-3">
                      <div class="stock-info">
                        <div class="info-icon">
                          <i class="ri-database-2-line"></i>
                        </div>
                        <div class="info-content">
                          <div class="info-value"><%= available_qty %> <%= @inventory_data[product.id][:unit] %></div>
                          <div class="info-label">Available</div>
                        </div>
                      </div>
                      <% if product.price && product.price > 0 %>
                        <div class="price-info">
                          <div class="info-icon">
                            <i class="ri-money-rupee-circle-line"></i>
                          </div>
                          <div class="info-content">
                            <div class="info-value price-value">₹<%= number_with_delimiter(product.price) %></div>
                            <div class="info-label">per <%= @inventory_data[product.id][:unit] %></div>
                          </div>
                        </div>
                      <% end %>
                    </div>

                    <!-- Enhanced Allocation Controls -->
                    <div id="allocation-controls-<%= product.id %>" class="allocation-controls mt-auto" style="display: none;">
                      <div class="allocation-separator"></div>
                      <div class="allocation-panel">
                        <div class="allocation-header">
                          <div class="allocation-icon">
                            <i class="ri-settings-4-line"></i>
                          </div>
                          <h6 class="allocation-title">Allocation Settings</h6>
                        </div>

                        <div class="allocation-inputs">
                          <div class="quantity-input-wrapper">
                            <label class="allocation-label">Quantity to Transfer</label>
                            <div class="input-group">
                              <%= number_field_tag "inventory_allocations[#{product.id}][quantity]",
                                  nil,
                                  class: "form-control allocation-quantity-input",
                                  placeholder: "0",
                                  min: 0,
                                  max: available_qty,
                                  step: 0.01,
                                  id: "qty-#{product.id}",
                                  onchange: "updateAllocation(#{product.id}, this.value, #{available_qty})" %>
                              <button type="button" class="btn btn-outline-primary allocation-max-btn" onclick="setMaxQuantity(<%= product.id %>, <%= available_qty %>)">
                                <i class="ri-upload-line"></i>
                              </button>
                            </div>
                            <%= hidden_field_tag "inventory_allocations[#{product.id}][product_name]", product.name %>
                            <%= hidden_field_tag "inventory_allocations[#{product.id}][unit]", @inventory_data[product.id][:unit] %>
                          </div>
                        </div>

                        <div class="allocation-summary">
                          <div class="allocation-stats">
                            <div class="stat-item remaining-stat" id="remaining-<%= product.id %>">
                              <div class="stat-icon">
                                <i class="ri-database-2-line"></i>
                              </div>
                              <div class="stat-content">
                                <span class="stat-value">Remaining: <span id="remaining-qty-<%= product.id %>"><%= available_qty %></span> <%= @inventory_data[product.id][:unit] %></span>
                              </div>
                            </div>
                            <% if product.price && product.price > 0 %>
                              <div class="stat-item value-stat" id="value-<%= product.id %>">
                                <div class="stat-icon">
                                  <i class="ri-money-rupee-circle-line"></i>
                                </div>
                                <div class="stat-content">
                                  <span class="stat-value">Value: ₹<span id="transfer-value-<%= product.id %>">0.00</span></span>
                                </div>
                              </div>
                            <% end %>
                          </div>
                        </div>

                        <div class="allocation-error" id="error-<%= product.id %>" style="display: none;">
                          <i class="ri-error-warning-line me-2"></i>
                          <span>Allocation cannot exceed available quantity</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- No Products Found Message -->
          <div id="no-products-message" class="text-center py-4" style="display: none;">
            <i class="ri-search-line text-muted" style="font-size: 2rem;"></i>
            <p class="text-muted mt-2">No products found matching your search criteria</p>
          </div>

          <div class="alert alert-info">
            <i class="ri-information-line me-2"></i>
            <strong>Note:</strong> Products will be transferred from central inventory to this store immediately upon creation.
            Remaining quantities will stay in central inventory for future allocations.
          </div>

          <div class="mt-3">
            <h6>Allocation Summary</h6>
            <div id="allocation-summary" class="text-muted">
              No products allocated yet
            </div>
          </div>
        <% else %>
          <div class="alert alert-warning">
            <i class="ri-alert-line me-2"></i>
            <strong>No Products Available:</strong> There are no products with available inventory in central storage to allocate to this store.
            You can add products later through the inventory transfer system.
          </div>
        <% end %>
          </div>
        </div>
      </div>

    </div>
  <% end %>

  <div class="pt-4">
    <%= form.submit store.new_record? ? "Create Store & Setup" : "Update Store", class: "btn btn-primary me-2" %>
    <%= link_to "Cancel", admin_stores_path, class: "btn btn-label-secondary" %>
  </div>

  <script>
    function toggleAdminSection() {
      const checkbox = document.querySelector('input[name="store[create_admin_user]"]');
      const section = document.getElementById('admin-section');
      const adminFields = ['admin_username', 'admin_email', 'admin_password', 'admin_first_name', 'admin_last_name', 'admin_mobile'];

      if (checkbox.checked) {
        section.style.display = 'block';
        adminFields.forEach(fieldId => {
          const field = document.getElementById(fieldId);
          if (field) field.required = true;
        });
      } else {
        section.style.display = 'none';
        adminFields.forEach(fieldId => {
          const field = document.getElementById(fieldId);
          if (field) field.required = false;
        });
      }
    }

    function updateAllocation(productId, allocatedQty, availableQty) {
      const remaining = availableQty - parseFloat(allocatedQty || 0);
      const remainingSpan = document.getElementById(`remaining-qty-${productId}`);
      const errorDiv = document.getElementById(`error-${productId}`);
      const input = document.querySelector(`input[name="inventory_allocations[${productId}][quantity]"]`);
      const transferValueSpan = document.getElementById(`transfer-value-${productId}`);
      const productCard = document.getElementById(`product-card-${productId}`);

      if (remaining < 0) {
        errorDiv.style.display = 'block';
        input.classList.add('is-invalid');
        remainingSpan.textContent = availableQty;
      } else {
        errorDiv.style.display = 'none';
        input.classList.remove('is-invalid');
        remainingSpan.textContent = remaining.toFixed(2);
      }

      // Update transfer value if price is available
      if (transferValueSpan && productCard) {
        const pricePerUnit = parseFloat(productCard.dataset.price || 0);
        const transferValue = (parseFloat(allocatedQty || 0) * pricePerUnit);
        transferValueSpan.textContent = transferValue.toFixed(2);
        console.log(`Product ${productId}: Qty=${allocatedQty}, Price=${pricePerUnit}, Value=${transferValue}`);
      }

      // Update visual selection if quantity > 0
      const checkbox = document.getElementById(`select-${productId}`);
      if (parseFloat(allocatedQty || 0) > 0) {
        if (!checkbox.checked) {
          checkbox.checked = true;
          toggleProductAllocation(productId);
        }
      }

      updateAllocationSummary();
    }

    function updateAllocationSummary() {
      const allocations = [];
      let totalValue = 0;
      let selectedCount = 0;

      // Update sidebar stats
      const selectedCountEl = document.getElementById('selected-count');
      const totalValueEl = document.getElementById('total-value');
      const selectedProductsList = document.getElementById('selected-products-list');

      // Get all quantity inputs and process them
      document.querySelectorAll('input[name*="inventory_allocations"][name*="[quantity]"]').forEach(input => {
        const qty = parseFloat(input.value || 0);
        if (qty > 0) {
          selectedCount++;
          const productId = input.name.match(/\[(\d+)\]/)[1];
          const productNameInput = document.querySelector(`input[name="inventory_allocations[${productId}][product_name]"]`);
          const unitInput = document.querySelector(`input[name="inventory_allocations[${productId}][unit]"]`);

          if (productNameInput && unitInput) {
            const productName = productNameInput.value;
            const unit = unitInput.value;

            // Get product price from data attribute
            const productCard = document.getElementById(`product-card-${productId}`);
            const pricePerUnit = parseFloat(productCard?.dataset?.price || 0);
            const itemValue = qty * pricePerUnit;
            totalValue += itemValue;

            console.log(`Summary - Product ${productId}: ${productName}, Qty: ${qty}, Price: ${pricePerUnit}, Value: ${itemValue}`);

            allocations.push({
              name: productName,
              qty: qty,
              unit: unit,
              value: itemValue,
              id: productId
            });
          }
        }
      });

      console.log(`Total selected: ${selectedCount}, Total value: ${totalValue}`);

      // Update sidebar statistics
      if (selectedCountEl) selectedCountEl.textContent = selectedCount;
      if (totalValueEl) totalValueEl.textContent = `₹${totalValue.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;

      // Update selected products list in sidebar
      if (selectedProductsList) {
        if (allocations.length > 0) {
          selectedProductsList.innerHTML = allocations.map(item => `
            <div class="selected-product-item mb-2 p-2 bg-white rounded border">
              <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                  <div class="fw-semibold text-truncate" style="font-size: 0.8rem;">${item.name}</div>
                  <div class="text-muted small">${item.qty} ${item.unit}</div>
                </div>
                <div class="text-end ms-2">
                  <div class="fw-bold text-primary" style="font-size: 0.75rem;">₹${item.value.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</div>
                </div>
              </div>
            </div>
          `).join('');
        } else {
          selectedProductsList.innerHTML = `
            <div class="empty-selection text-center py-4">
              <i class="ri-shopping-cart-line text-muted mb-2" style="font-size: 2rem;"></i>
              <p class="text-muted mb-0">No products selected yet</p>
              <small class="text-muted">Select products from the grid to see them here</small>
            </div>
          `;
        }
      }

      // Also update the old summary for backward compatibility
      const summaryDiv = document.getElementById('allocation-summary');
      if (summaryDiv) {
        if (allocations.length > 0) {
          summaryDiv.innerHTML = `
            <strong>Selected Products (${selectedCount}):</strong><br>
            ${allocations.map(item => `${item.name}: ${item.qty} ${item.unit} (₹${item.value.toFixed(2)})`).join('<br>')}
            <hr>
            <strong>Total Transfer Value: ₹${totalValue.toFixed(2)}</strong>
          `;
        } else {
          summaryDiv.innerHTML = 'No products allocated yet';
        }
      }
    }


    function optimizeAllocation() {
      // Smart allocation: Select products with available stock, allocate 30% of available
      clearAllProducts();

      setTimeout(() => {
        document.querySelectorAll('.product-checkbox').forEach(checkbox => {
          const productId = checkbox.id.replace('select-', '');
          const qtyInput = document.getElementById(`qty-${productId}`);
          const maxQty = parseFloat(qtyInput?.max || 0);

          // Only select if available quantity > 5
          if (maxQty > 5) {
            checkbox.checked = true;
            toggleProductAllocation(productId);

            // Wait for controls to be shown then set quantity
            setTimeout(() => {
              // Allocate 30% of available stock (rounded)
              const smartQty = Math.max(1, Math.round(maxQty * 0.3));
              qtyInput.value = smartQty;
              updateAllocation(productId, smartQty, maxQty);
            }, 200);
          }
        });

        // Final update after all selections
        setTimeout(() => {
          updateAllocationSummary();
        }, 1000);
      }, 100);
    }

    // Enhanced inventory allocation functions with visual effects
    function toggleProductAllocation(productId) {
      const checkbox = document.getElementById(`select-${productId}`);
      const controls = document.getElementById(`allocation-controls-${productId}`);
      const card = document.getElementById(`product-card-${productId}`);
      const overlay = card.querySelector('.selection-overlay');

      if (checkbox.checked) {
        // Add visual effects
        card.classList.add('border-primary', 'selected-card');

        // Show overlay with animation
        if (overlay) {
          overlay.style.opacity = '1';
        }

        // Show allocation controls
        if (controls) {
          controls.style.display = 'block';
          setTimeout(() => {
            controls.style.opacity = '1';
            controls.style.transform = 'translateY(0)';
          }, 50);
        }

      } else {
        // Remove visual effects
        card.classList.remove('border-primary', 'selected-card');

        // Hide overlay
        if (overlay) {
          overlay.style.opacity = '0';
        }

        // Hide allocation controls
        if (controls) {
          controls.style.opacity = '0';
          controls.style.transform = 'translateY(-10px)';
          setTimeout(() => {
            controls.style.display = 'none';
          }, 300);
        }

        // Clear the quantity input and reset values
        const qtyInput = document.getElementById(`qty-${productId}`);
        if (qtyInput) {
          qtyInput.value = '';
          // Reset remaining quantity
          const remainingSpan = document.getElementById(`remaining-qty-${productId}`);
          const maxQty = parseFloat(qtyInput.max);
          if (remainingSpan) {
            remainingSpan.textContent = maxQty;
          }
          // Reset transfer value
          const transferValueSpan = document.getElementById(`transfer-value-${productId}`);
          if (transferValueSpan) {
            transferValueSpan.textContent = '0.00';
          }
        }
      }

      updateAllocationSummary();
    }

    function setMaxQuantity(productId, maxQty) {
      const qtyInput = document.getElementById(`qty-${productId}`);
      const checkbox = document.getElementById(`select-${productId}`);

      if (qtyInput) {
        qtyInput.value = maxQty;

        // Ensure product is selected
        if (!checkbox.checked) {
          checkbox.checked = true;
          toggleProductAllocation(productId);
        }

        updateAllocation(productId, maxQty, maxQty);
      }
    }

    function selectAllProducts() {
      document.querySelectorAll('.product-checkbox:not(:checked)').forEach(checkbox => {
        checkbox.checked = true;
        const productId = checkbox.id.replace('select-', '');
        toggleProductAllocation(productId);

        // Set a default quantity (10% of available or minimum 1)
        setTimeout(() => {
          const qtyInput = document.getElementById(`qty-${productId}`);
          if (qtyInput) {
            const maxQty = parseFloat(qtyInput.max);
            const defaultQty = Math.max(1, Math.round(maxQty * 0.1));
            qtyInput.value = defaultQty;
            updateAllocation(productId, defaultQty, maxQty);
          }
        }, 100);
      });
    }

    function clearAllProducts() {
      document.querySelectorAll('.product-checkbox:checked').forEach(checkbox => {
        checkbox.checked = false;
        const productId = checkbox.id.replace('select-', '');
        toggleProductAllocation(productId);
      });
      updateAllocationSummary();
    }

    function filterProducts() {
      const searchTerm = document.getElementById('product-search').value.toLowerCase();
      const categoryFilter = document.getElementById('category-filter').value;
      const productCards = document.querySelectorAll('.product-card');
      let visibleCount = 0;

      productCards.forEach(card => {
        const productName = card.dataset.productName;
        const productSku = card.dataset.productSku;
        const category = card.dataset.category;

        const matchesSearch = searchTerm === '' ||
                            productName.includes(searchTerm) ||
                            productSku.includes(searchTerm);
        const matchesCategory = categoryFilter === '' || category === categoryFilter;

        if (matchesSearch && matchesCategory) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      // Show/hide no products message
      const noProductsMessage = document.getElementById('no-products-message');
      if (visibleCount === 0) {
        noProductsMessage.style.display = 'block';
      } else {
        noProductsMessage.style.display = 'none';
      }
    }

    // Load products for a specific store (for editing existing stores)
    function loadStoreProducts(storeId) {
      if (!storeId) return;

      fetch(`/admin/stores/get_product_availability?store_id=${storeId}`, {
        method: 'GET',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          updateProductCards(data.products);
          updateSidebarStats(data.summary);
        } else {
          console.error('Error loading products:', data.error);
        }
      })
      .catch(error => {
        console.error('Error fetching products:', error);
      });
    }

    // Update product cards with fresh inventory data
    function updateProductCards(products) {
      products.forEach(product => {
        const card = document.getElementById(`product-card-${product.id}`);
        if (card) {
          const availableSpan = card.querySelector('.text-success');
          if (availableSpan) {
            availableSpan.innerHTML = `<i class="ri-package-line me-1"></i>${product.central_available} ${product.unit}`;
          }
        }
      });
    }

    // Refresh all inventory data
    function refreshInventoryData() {
      const loadingOverlay = document.createElement('div');
      loadingOverlay.className = 'position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center';
      loadingOverlay.style.backgroundColor = 'rgba(0,0,0,0.5)';
      loadingOverlay.style.zIndex = '9999';
      loadingOverlay.innerHTML = `
        <div class="bg-white p-4 rounded shadow">
          <div class="text-center">
            <div class="spinner-border text-primary mb-2" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
            <div>Refreshing inventory data...</div>
          </div>
        </div>
      `;
      document.body.appendChild(loadingOverlay);

      // Simulate refresh (in real implementation, this would fetch fresh data)
      setTimeout(() => {
        document.body.removeChild(loadingOverlay);
        updateAllocationSummary(); // Refresh the summary
      }, 1500);
    }

    // Initialize admin section visibility and add event listeners
    document.addEventListener('DOMContentLoaded', function() {
      toggleAdminSection();

      // Add event listeners for search and filter
      const searchInput = document.getElementById('product-search');
      const categoryFilter = document.getElementById('category-filter');

      if (searchInput) {
        searchInput.addEventListener('input', filterProducts);
      }

      if (categoryFilter) {
        categoryFilter.addEventListener('change', filterProducts);
      }

    });
  </script>

