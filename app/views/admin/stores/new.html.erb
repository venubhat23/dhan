<div class="content-wrapper">
  <div class="container-xxl flex-grow-1 container-p-y">
    <!-- Header -->
    <div class="row">
      <div class="col-12">
        <div class="card mb-4">
          <div class="card-header d-flex align-items-center justify-content-between">
            <div>
              <h4 class="mb-0">
                <i class="ri-store-add-line me-2"></i>Create New Store
              </h4>
              <p class="mb-0 text-muted">Set up a new store with admin account and initial inventory</p>
            </div>
            <div>
              <% unless Store.can_add_more_stores? %>
                <div class="alert alert-warning mb-0">
                  <i class="ri-error-warning-line me-1"></i>
                  Maximum <%= Store::MAX_STORES_LIMIT %> stores allowed
                </div>
              <% else %>
                <span class="badge bg-success">
                  <%= Store.remaining_store_slots %> slots remaining
                </span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Form Section -->
    <div class="row">
      <div class="col-12">
        <%= render 'form', store: @store %>
      </div>
    </div>

    <!-- Help Section -->
    <% if @available_products&.any? %>
      <div class="row">
        <div class="col-12">
          <div class="card mt-4">
            <div class="card-header">
              <h6 class="mb-0">
                <i class="ri-lightbulb-line me-2"></i>Quick Help
              </h6>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-4">
                  <h6 class="text-primary">Store Information</h6>
                  <ul class="small text-muted">
                    <li>Provide complete store details</li>
                    <li>Ensure contact information is accurate</li>
                    <li>Enable inventory management for this store</li>
                  </ul>
                </div>
                <div class="col-md-4">
                  <h6 class="text-primary">Store Admin Setup</h6>
                  <ul class="small text-muted">
                    <li>Admin will receive login credentials</li>
                    <li>Admin can only access this store's data</li>
                    <li>Admin can manage inventory and bookings</li>
                  </ul>
                </div>
                <div class="col-md-4">
                  <h6 class="text-primary">Inventory Allocation</h6>
                  <ul class="small text-muted">
                    <li>Transfer products from central inventory</li>
                    <li>Remaining stock stays in central inventory</li>
                    <li>Can request more inventory later via transfers</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>