<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Inventory Transfer</h2>
    <p class="text-muted mb-0">Transfer stock from main inventory to <%= @store.name %></p>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <%= link_to admin_stores_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Stores
    <% end %>
  </div>
</div>

<!-- Store Info Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h5 class="card-title mb-1">
          <i class="bi bi-shop me-2"></i>
          <%= @store.name %>
        </h5>
        <p class="text-muted mb-0">
          <i class="bi bi-geo-alt me-1"></i>
          <%= @store.address %>, <%= @store.city %>, <%= @store.state %> - <%= @store.pincode %>
        </p>
      </div>
      <div class="col-md-4 text-end">
        <span class="badge bg-<%= @store.status? ? 'success' : 'danger' %>-subtle text-<%= @store.status? ? 'success' : 'danger' %> px-3 py-2">
          <i class="bi bi-<%= @store.status? ? 'check' : 'x' %>-circle me-1"></i>
          <%= @store.status? ? 'Active' : 'Inactive' %>
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Transfer Form -->
<%= form_with url: process_transfer_admin_store_path(@store), method: :post, local: true, id: 'transfer-form' do |form| %>
  <div class="row">
    <!-- Products Selection -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
              <i class="bi bi-box-seam me-2"></i>
              Available Products
            </h5>
            <div class="d-flex gap-2">
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAll()">
                <i class="bi bi-check-all me-1"></i>
                Select All
              </button>
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearAll()">
                <i class="bi bi-x me-1"></i>
                Clear All
              </button>
            </div>
          </div>
        </div>
        <div class="card-body p-0">
          <% if @inventory_data.any? %>
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="border-0 fw-semibold">Product Details</th>
                    <th class="border-0 fw-semibold text-center">Available Stock</th>
                    <th class="border-0 fw-semibold text-center">Store Stock & Price</th>
                    <th class="border-0 fw-semibold text-center" style="width: 200px;">Transfer Quantity</th>
                  </tr>
                </thead>
                <tbody>
                  <% @inventory_data.each do |product_id, data| %>
                    <tr class="product-row" data-product-id="<%= product_id %>" data-price="<%= data[:price] %>">
                      <td class="align-middle">
                        <div class="d-flex align-items-center">
                          <div class="avatar-sm bg-primary-subtle rounded-circle d-flex align-items-center justify-content-center me-3">
                            <i class="bi bi-box text-primary"></i>
                          </div>
                          <div>
                            <h6 class="mb-0"><%= data[:product].name %></h6>
                            <small class="text-muted">
                              <%= data[:product].category&.name || 'No Category' %> |
                              <%= data[:unit] %>
                            </small>
                          </div>
                        </div>
                      </td>
                      <td class="align-middle text-center">
                        <span class="badge bg-<%= data[:central_available] > 0 ? 'success' : 'danger' %>-subtle text-<%= data[:central_available] > 0 ? 'success' : 'danger' %> px-3 py-2 fs-6">
                          <%= data[:central_available] %> <%= data[:unit] %>
                        </span>
                      </td>
                      <td class="align-middle text-center">
                        <div class="mb-1">
                          <span class="badge bg-info-subtle text-info px-2 py-1">
                            Store: <%= data[:store_current] %> <%= data[:unit] %>
                          </span>
                        </div>
                        <div>
                          <strong class="text-primary">₹<%= '%.2f' % data[:price] %></strong>
                          <small class="text-muted d-block">per <%= data[:unit] %></small>
                        </div>
                      </td>
                      <td class="align-middle">
                        <div class="d-flex align-items-center justify-content-center gap-2">
                          <div class="input-group" style="max-width: 180px;">
                            <button type="button" class="btn btn-outline-secondary btn-sm quantity-btn" onclick="decreaseQuantity('<%= product_id %>')">
                              <i class="bi bi-dash"></i>
                            </button>
                            <input type="number"
                                   name="transfer_items[<%= product_id %>]"
                                   class="form-control text-center quantity-input"
                                   value="0"
                                   min="0"
                                   max="<%= data[:central_available] %>"
                                   step="0.1"
                                   data-product-id="<%= product_id %>"
                                   onchange="updateSummary()"
                                   style="font-size: 1rem; padding: 0.5rem;">
                            <button type="button" class="btn btn-outline-secondary btn-sm quantity-btn" onclick="increaseQuantity('<%= product_id %>')">
                              <i class="bi bi-plus"></i>
                            </button>
                          </div>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5">
              <div class="mb-3">
                <i class="bi bi-box fs-1 text-muted"></i>
              </div>
              <h5 class="text-muted mb-3">No Products Available</h5>
              <p class="text-muted">There are no products available in the main inventory for transfer.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Transfer Summary -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
        <div class="card-header bg-transparent border-0">
          <h5 class="mb-0">
            <i class="bi bi-calculator me-2"></i>
            Transfer Summary
          </h5>
        </div>
        <div class="card-body">
          <div class="summary-item d-flex justify-content-between mb-3">
            <span class="text-muted">Total Products:</span>
            <span class="fw-bold" id="total-products">0</span>
          </div>
          <div class="summary-item d-flex justify-content-between mb-3">
            <span class="text-muted">Total Quantity:</span>
            <span class="fw-bold" id="total-quantity">0</span>
          </div>
          <div class="summary-item d-flex justify-content-between mb-4">
            <span class="text-muted">Total Value:</span>
            <span class="fw-bold text-primary fs-5" id="total-value">₹0.00</span>
          </div>

          <hr class="my-3">

          <div class="summary-item d-flex justify-content-between mb-3">
            <span class="text-muted small">Available Inventory Value:</span>
            <span class="small">₹<%= '%.2f' % @total_available_value %></span>
          </div>

          <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary" id="transfer-btn" disabled>
              <i class="bi bi-arrow-right me-2"></i>
              Transfer to Store
            </button>
            <button type="button" class="btn btn-outline-secondary" onclick="clearAll()">
              <i class="bi bi-arrow-clockwise me-2"></i>
              Reset Selection
            </button>
          </div>

          <div class="mt-4 p-3 bg-light rounded">
            <h6 class="text-muted mb-2">
              <i class="bi bi-info-circle me-1"></i>
              Transfer Details
            </h6>
            <ul class="list-unstyled mb-0 small" id="selected-items">
              <li class="text-muted">No items selected</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize
  updateSummary();

  // Add event listeners to all quantity inputs
  document.querySelectorAll('.quantity-input').forEach(input => {
    input.addEventListener('input', updateSummary);
    input.addEventListener('change', updateSummary);
  });
});

function increaseQuantity(productId) {
  const input = document.querySelector(`input[data-product-id="${productId}"]`);
  const max = parseFloat(input.getAttribute('max'));
  const current = parseFloat(input.value) || 0;
  const step = parseFloat(input.getAttribute('step')) || 1;

  if (current + step <= max) {
    input.value = (current + step).toFixed(1);
    updateSummary();
  }
}

function decreaseQuantity(productId) {
  const input = document.querySelector(`input[data-product-id="${productId}"]`);
  const current = parseFloat(input.value) || 0;
  const step = parseFloat(input.getAttribute('step')) || 1;

  if (current - step >= 0) {
    input.value = Math.max(0, (current - step).toFixed(1));
    updateSummary();
  }
}

function selectAll() {
  document.querySelectorAll('.quantity-input').forEach(input => {
    const max = parseFloat(input.getAttribute('max'));
    if (max > 0) {
      input.value = Math.min(max, 10); // Set to 10 or max available, whichever is smaller
    }
  });
  updateSummary();
}

function clearAll() {
  document.querySelectorAll('.quantity-input').forEach(input => {
    input.value = 0;
  });
  updateSummary();
}

function updateSummary() {
  let totalProducts = 0;
  let totalQuantity = 0;
  let totalValue = 0;
  const selectedItems = [];

  document.querySelectorAll('.quantity-input').forEach(input => {
    const quantity = parseFloat(input.value) || 0;

    if (quantity > 0) {
      const productId = input.getAttribute('data-product-id');
      const row = document.querySelector(`tr[data-product-id="${productId}"]`);
      const price = parseFloat(row.getAttribute('data-price'));
      const productName = row.querySelector('h6').textContent;
      const unit = row.querySelector('small').textContent.split('|')[1].trim();

      totalProducts++;
      totalQuantity += quantity;
      totalValue += quantity * price;

      selectedItems.push({
        name: productName,
        quantity: quantity,
        unit: unit,
        value: quantity * price
      });
    }
  });

  // Update summary display
  document.getElementById('total-products').textContent = totalProducts;
  document.getElementById('total-quantity').textContent = totalQuantity.toFixed(1);
  document.getElementById('total-value').textContent = `₹${totalValue.toFixed(2)}`;

  // Update transfer button
  const transferBtn = document.getElementById('transfer-btn');
  transferBtn.disabled = totalProducts === 0;

  // Update selected items list
  const selectedItemsList = document.getElementById('selected-items');
  if (selectedItems.length > 0) {
    selectedItemsList.innerHTML = selectedItems.map(item =>
      `<li class="d-flex justify-content-between">
        <span>${item.name}</span>
        <small>${item.quantity} ${item.unit} - ₹${item.value.toFixed(2)}</small>
      </li>`
    ).join('');
  } else {
    selectedItemsList.innerHTML = '<li class="text-muted">No items selected</li>';
  }

  // Add visual feedback to rows with quantities
  document.querySelectorAll('.product-row').forEach(row => {
    const productId = row.getAttribute('data-product-id');
    const input = document.querySelector(`input[data-product-id="${productId}"]`);
    const quantity = parseFloat(input.value) || 0;

    if (quantity > 0) {
      row.style.backgroundColor = '#f8f9fa';
      row.style.borderLeft = '3px solid #0d6efd';
    } else {
      row.style.backgroundColor = '';
      row.style.borderLeft = '';
    }
  });
}

// Add form validation before submission
document.getElementById('transfer-form').addEventListener('submit', function(e) {
  const hasItems = document.querySelectorAll('.quantity-input').some(input =>
    parseFloat(input.value) > 0
  );

  if (!hasItems) {
    e.preventDefault();
    alert('Please select at least one product to transfer.');
    return false;
  }

  // Show loading state
  const transferBtn = document.getElementById('transfer-btn');
  transferBtn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-2"></i>Processing Transfer...';
  transferBtn.disabled = true;
});
</script>

<style>
/* Spinner animation */
.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Enhanced input styling */
.quantity-input {
  font-weight: 600;
  border: 2px solid #e9ecef;
  transition: all 0.2s ease;
}

.quantity-input:focus {
  border-color: #0d6efd;
  box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
}

/* Button hover effects */
.quantity-btn:hover {
  transform: scale(1.05);
}

/* Card hover effects */
.card {
  transition: all 0.3s ease;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(0,0,0,0.1) !important;
}

/* Summary card styling */
.sticky-top {
  transition: all 0.3s ease;
}

/* Table row hover effects */
.table-hover tbody tr:hover {
  background-color: #f8f9fa;
  transform: scale(1.01);
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  transition: all 0.2s ease;
}

/* Badge styling */
.badge {
  font-size: 0.85rem;
  font-weight: 500;
}

/* Avatar styling */
.avatar-sm {
  width: 40px;
  height: 40px;
}

/* Enhanced button styling */
.btn {
  border-radius: 8px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn:hover {
  transform: translateY(-1px);
}

/* Summary item styling */
.summary-item {
  padding: 0.5rem 0;
  border-bottom: 1px solid #f1f3f4;
}

.summary-item:last-child {
  border-bottom: none;
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .sticky-top {
    position: relative !important;
    top: auto !important;
  }

  .table-responsive {
    font-size: 0.875rem;
  }

  .input-group {
    max-width: 160px !important;
  }
}
</style>