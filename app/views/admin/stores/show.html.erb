<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= @store.name %></h2>
    <p class="text-muted mb-0">
      <i class="bi bi-geo-alt me-1"></i>
      <%= @store.city %>, <%= @store.state %>
      <% if @store.status %>
        <span class="badge bg-success ms-2">Active</span>
      <% else %>
        <span class="badge bg-danger ms-2">Inactive</span>
      <% end %>
    </p>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <%= link_to edit_admin_store_path(@store), class: "btn btn-outline-primary" do %>
      <i class="bi bi-pencil me-1"></i>
      Edit Store
    <% end %>
    <%= link_to admin_stores_path, class: "btn btn-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>
      Back to Stores
    <% end %>
  </div>
</div>

<!-- Quick Stats Cards -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-3">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Total Bookings</h6>
            <h4 class="mb-0 text-primary"><%= @bookings_count %></h4>
          </div>
          <div class="text-primary">
            <i class="bi bi-calendar-check fs-3"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-3">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Products in Stock</h6>
            <h4 class="mb-0 text-success"><%= @store.store_products_with_inventory.count %></h4>
          </div>
          <div class="text-success">
            <i class="bi bi-box-seam fs-3"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-3">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Low Stock Items</h6>
            <h4 class="mb-0 text-warning"><%= @store.low_stock_products.count %></h4>
          </div>
          <div class="text-warning">
            <i class="bi bi-exclamation-triangle fs-3"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-3">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <h6 class="text-muted mb-1">Inventory Value</h6>
            <h4 class="mb-0 text-info">₹<%= number_with_delimiter(@store.store_inventory_summary[:total_stock_value] || 0) %></h4>
          </div>
          <div class="text-info">
            <i class="bi bi-currency-rupee fs-3"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="row">
  <!-- Store Information -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0">
          <i class="bi bi-info-circle me-2"></i>
          Store Information
        </h5>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Store Name</label>
            <p class="fw-semibold mb-0"><%= @store.name %></p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Contact Person</label>
            <p class="fw-semibold mb-0"><%= @store.contact_person %></p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Mobile Number</label>
            <p class="fw-semibold mb-0">
              <i class="bi bi-phone me-1"></i>
              <%= @store.contact_mobile %>
            </p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Email Address</label>
            <p class="fw-semibold mb-0">
              <% if @store.email.present? %>
                <i class="bi bi-envelope me-1"></i>
                <%= @store.email %>
              <% else %>
                <span class="text-muted">Not provided</span>
              <% end %>
            </p>
          </div>
          <div class="col-md-12 mb-3">
            <label class="form-label text-muted">Address</label>
            <p class="fw-semibold mb-0">
              <i class="bi bi-geo-alt me-1"></i>
              <%= @store.full_address %>
            </p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">GST Number</label>
            <p class="fw-semibold mb-0">
              <% if @store.gst_no.present? %>
                <%= @store.gst_no %>
              <% else %>
                <span class="text-muted">Not provided</span>
              <% end %>
            </p>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label text-muted">Status</label>
            <p class="fw-semibold mb-0">
              <% if @store.status %>
                <span class="badge bg-success">Active</span>
              <% else %>
                <span class="badge bg-danger">Inactive</span>
              <% end %>
            </p>
          </div>
          <% if @store.description.present? %>
          <div class="col-md-12 mb-3">
            <label class="form-label text-muted">Description</label>
            <p class="fw-semibold mb-0"><%= @store.description %></p>
          </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Admin Information -->
    <% if @store.store_admin_user.present? %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0">
          <i class="bi bi-person-badge me-2"></i>
          Store Administrator
        </h5>
      </div>
      <div class="card-body">
        <div class="row align-items-center">
          <div class="col-md-2">
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
              <i class="bi bi-person fs-4"></i>
            </div>
          </div>
          <div class="col-md-10">
            <h6 class="mb-1"><%= @store.store_admin_user.full_name %></h6>
            <p class="text-muted mb-1">
              <i class="bi bi-envelope me-1"></i>
              <%= @store.store_admin_user.email %>
            </p>
            <p class="text-muted mb-1">
              <i class="bi bi-phone me-1"></i>
              <%= @store.store_admin_user.mobile %>
            </p>

            <!-- Admin Login Credentials -->
            <div class="mt-3 p-3 bg-light rounded border">
              <h6 class="mb-2 text-primary">
                <i class="bi bi-key me-1"></i>
                Login Credentials
              </h6>
              <div class="row">
                <div class="col-md-6">
                  <label class="form-label text-muted small">Username/Email</label>
                  <p class="mb-1 fw-semibold">
                    <%= @store.store_admin_user.email %>
                  </p>
                </div>
                <div class="col-md-6">
                  <label class="form-label text-muted small">Password</label>
                  <p class="mb-1 fw-semibold">
                    <span style="font-family: monospace;"><%= @store.admin_plain_password || "••••••••" %></span>
                  </p>
                  <small class="text-muted">
                    <% if @store.admin_plain_password.present? %>
                      Password set during store creation
                    <% else %>
                      Password not saved (created before update)
                    <% end %>
                  </small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% else %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0">
          <i class="bi bi-person-badge me-2"></i>
          Store Administrator
        </h5>
      </div>
      <div class="card-body text-center py-4">
        <i class="bi bi-person-x text-muted" style="font-size: 3rem;"></i>
        <p class="text-muted mt-2 mb-0">No administrator assigned to this store</p>
        <%= link_to "Assign Admin", assign_admin_admin_store_path(@store), class: "btn btn-outline-primary btn-sm mt-2" %>
      </div>
    </div>
    <% end %>
  </div>

  <!-- Right Sidebar -->
  <div class="col-lg-4">
    <!-- Quick Actions -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0">
          <i class="bi bi-lightning me-2"></i>
          Quick Actions
        </h5>
      </div>
      <div class="card-body p-0">
        <div class="list-group list-group-flush">
          <%= link_to current_stock_admin_store_path(@store), class: "list-group-item list-group-item-action d-flex align-items-center" do %>
            <i class="bi bi-boxes text-success me-3"></i>
            <div>
              <h6 class="mb-1">Current Stock</h6>
              <small class="text-muted">View current inventory levels</small>
            </div>
          <% end %>

          <%= link_to inventory_admin_store_path(@store), class: "list-group-item list-group-item-action d-flex align-items-center" do %>
            <i class="bi bi-box-seam text-primary me-3"></i>
            <div>
              <h6 class="mb-1">View Inventory</h6>
              <small class="text-muted">Manage store stock and products</small>
            </div>
          <% end %>

          <%= link_to transfer_inventory_admin_store_path(@store), class: "list-group-item list-group-item-action d-flex align-items-center" do %>
            <i class="bi bi-arrow-left-right text-success me-3"></i>
            <div>
              <h6 class="mb-1">Transfer Inventory</h6>
              <small class="text-muted">Move stock between stores</small>
            </div>
          <% end %>

          <%= link_to admin_bookings_path(store_id: @store.id), class: "list-group-item list-group-item-action d-flex align-items-center" do %>
            <i class="bi bi-calendar-check text-info me-3"></i>
            <div>
              <h6 class="mb-1">View Bookings</h6>
              <small class="text-muted">See all store bookings</small>
            </div>
          <% end %>

          <% if @store.store_admin_user.blank? %>
          <%= link_to assign_admin_admin_store_path(@store), class: "list-group-item list-group-item-action d-flex align-items-center" do %>
            <i class="bi bi-person-plus text-warning me-3"></i>
            <div>
              <h6 class="mb-1">Assign Admin</h6>
              <small class="text-muted">Set store administrator</small>
            </div>
          <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Store Status -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0">
          <i class="bi bi-gear me-2"></i>
          Store Settings
        </h5>
      </div>
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h6 class="mb-1">Store Status</h6>
            <small class="text-muted">Toggle store availability</small>
          </div>
          <%= link_to toggle_status_admin_store_path(@store), method: :patch,
                      class: "btn btn-sm #{'btn-success' if @store.status} #{'btn-outline-danger' unless @store.status}",
                      data: { confirm: "Are you sure you want to #{@store.status ? 'deactivate' : 'activate'} this store?" } do %>
            <% if @store.status %>
              <i class="bi bi-check-circle me-1"></i>Active
            <% else %>
              <i class="bi bi-x-circle me-1"></i>Inactive
            <% end %>
          <% end %>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h6 class="mb-1">Inventory Management</h6>
            <small class="text-muted">Stock tracking enabled</small>
          </div>
          <span class="badge bg-<%= @store.inventory_management_enabled? ? 'success' : 'secondary' %>">
            <%= @store.inventory_management_enabled? ? 'Enabled' : 'Disabled' %>
          </span>
        </div>

        <hr>

        <div class="d-grid">
          <%= link_to edit_admin_store_path(@store), class: "btn btn-outline-primary" do %>
            <i class="bi bi-pencil me-1"></i>
            Edit Store Details
          <% end %>
        </div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0">
          <i class="bi bi-activity me-2"></i>
          Recent Activity
        </h5>
      </div>
      <div class="card-body">
        <% recent_transfers = @store.transfer_history(5) %>
        <% if recent_transfers.any? %>
          <% recent_transfers.each do |transfer| %>
            <div class="d-flex align-items-start mb-3">
              <div class="me-2">
                <% if transfer.from_store_id == @store.id %>
                  <i class="bi bi-arrow-up-right text-danger"></i>
                <% else %>
                  <i class="bi bi-arrow-down-left text-success"></i>
                <% end %>
              </div>
              <div class="flex-grow-1">
                <p class="mb-1 small">
                  <strong><%= transfer.product.name %></strong>
                  <span class="text-muted">
                    (<%= transfer.quantity %> <%= transfer.product.unit_type %>)
                  </span>
                </p>
                <p class="mb-0 text-muted small">
                  <% if transfer.from_store_id == @store.id %>
                    Sent to <%= transfer.to_store&.name || 'Central' %>
                  <% else %>
                    Received from <%= transfer.from_store&.name || 'Central' %>
                  <% end %>
                  <br>
                  <%= time_ago_in_words(transfer.created_at) %> ago
                </p>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-3">
            <i class="bi bi-clock-history text-muted" style="font-size: 2rem;"></i>
            <p class="text-muted mt-2 mb-0">No recent activity</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Delete Store Modal (if can be deleted) -->
<% if @store.can_be_deleted? %>
<div class="modal fade" id="deleteStoreModal" tabindex="-1" aria-labelledby="deleteStoreModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title text-danger" id="deleteStoreModalLabel">
          <i class="bi bi-exclamation-triangle me-2"></i>
          Delete Store
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to permanently delete <strong><%= @store.name %></strong>?</p>
        <p class="text-muted small mb-0">This action cannot be undone.</p>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <%= link_to admin_store_path(@store), method: :delete,
                    class: "btn btn-danger",
                    data: { confirm: "Type 'DELETE' to confirm deletion" } do %>
          <i class="bi bi-trash me-1"></i>
          Delete Store
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Add Delete Button to Header if can be deleted -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  <% if @store.can_be_deleted? %>
  const headerActions = document.querySelector('.d-flex.gap-2.align-items-center');
  const deleteBtn = `
    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteStoreModal">
      <i class="bi bi-trash me-1"></i>
      Delete
    </button>
  `;
  headerActions.insertAdjacentHTML('beforeend', deleteBtn);
  <% end %>
});

</script>
<% end %>