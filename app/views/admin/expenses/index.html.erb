<% content_for :page_title, "All Store Expenses" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Store Expenses Management</h4>
    <small class="text-muted">Monitor and manage expenses across all stores</small>
  </div>
  <div>
    <%= link_to new_admin_expense_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus me-2"></i>Add Expense
    <% end %>
  </div>
</div>

<!-- Custom CSS for Expenses Cards -->
<style>
.expense-card {
  border-radius: 12px !important;
  transition: transform 0.2s ease, box-shadow 0.2s ease !important;
  background: linear-gradient(135deg, #ffffff 0%, #f7fafc 100%) !important;
  border: 1px solid #e2e8f0 !important;
  min-height: 120px;
}
.expense-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
}
.expense-card-blue {
  border-left: 4px solid #3b82f6 !important;
}
.expense-card-cyan {
  border-left: 4px solid #06b6d4 !important;
}
.expense-card-green {
  border-left: 4px solid #10b981 !important;
}
.expense-card-purple {
  border-left: 4px solid #8b5cf6 !important;
}
.expense-card-title {
  color: #2d3748 !important;
  font-weight: 600 !important;
  font-size: 0.9rem !important;
}
.expense-card-value {
  color: #1a202c !important;
  font-weight: 800 !important;
  font-size: 1.8rem !important;
  line-height: 1.1 !important;
}
.expense-card-icon {
  color: rgba(45, 55, 72, 0.2) !important;
  font-size: 3rem !important;
}
</style>

<!-- Summary Cards -->
<div class="row mb-4">
  <div class="col-md-3 mb-3">
    <div class="card shadow-sm expense-card expense-card-blue">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div class="flex-grow-1">
          <h6 class="card-title mb-2 expense-card-title">Total Expenses</h6>
          <div class="expense-card-value">₹<%= number_with_delimiter(@total_expenses.to_f.round(0)) %></div>
          <small class="text-muted">all stores, all time</small>
        </div>
        <div>
          <i class="bi bi-receipt expense-card-icon"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3">
    <div class="card shadow-sm expense-card expense-card-cyan">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div class="flex-grow-1">
          <h6 class="card-title mb-2 expense-card-title">This Month</h6>
          <div class="expense-card-value">₹<%= number_with_delimiter(@monthly_expenses.to_f.round(0)) %></div>
          <small class="text-muted">current month spending</small>
        </div>
        <div>
          <i class="bi bi-calendar-month expense-card-icon"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3">
    <div class="card shadow-sm expense-card expense-card-green">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div class="flex-grow-1">
          <h6 class="card-title mb-2 expense-card-title">Categories</h6>
          <div class="expense-card-value"><%= @category_breakdown.keys.count %></div>
          <small class="text-muted">expense categories</small>
        </div>
        <div>
          <i class="bi bi-tags expense-card-icon"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3">
    <div class="card shadow-sm expense-card expense-card-purple">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div class="flex-grow-1">
          <h6 class="card-title mb-2 expense-card-title">Active Stores</h6>
          <div class="expense-card-value"><%= @store_breakdown.keys.count %></div>
          <small class="text-muted">stores with expenses</small>
        </div>
        <div>
          <i class="bi bi-shop expense-card-icon"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-3">
    <%= form_tag admin_expenses_path, method: :get, local: true, class: "row g-3 align-items-end" do %>
      <div class="col-md-2">
        <label class="form-label small">Start Date</label>
        <%= date_field_tag :start_date, params[:start_date], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label small">End Date</label>
        <%= date_field_tag :end_date, params[:end_date], class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-2">
        <label class="form-label small">Category</label>
        <%= select_tag :category,
            options_for_select([["All Categories", ""]] + Expense::CATEGORIES.map { |cat| [cat, cat] }, params[:category]),
            class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-3">
        <label class="form-label small">Store / Location</label>
        <%= select_tag :store_id,
            options_for_select([
              ["All Locations", ""],
              ["Main Inventory", "main_inventory"]
            ] + @stores.map { |store| [store.name, store.id] }, params[:store_id]),
            class: "form-select form-select-sm" %>
      </div>
      <div class="col-md-3">
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-funnel me-1"></i>Filter
          </button>
          <%= link_to admin_expenses_path, class: "btn btn-outline-secondary btn-sm" do %>
            <i class="bi bi-x me-1"></i>Clear
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Expenses List -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-0">
    <h6 class="mb-0"><i class="bi bi-list me-2"></i>Expense Records</h6>
  </div>
  <div class="card-body p-0">
    <% if @expenses.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Date</th>
              <th>Store</th>
              <th>Title</th>
              <th>Category</th>
              <th>Amount</th>
              <th>Created By</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @expenses.each do |expense| %>
              <tr>
                <td>
                  <strong><%= expense.expense_date.strftime('%d %b %Y') %></strong>
                  <div class="small text-muted"><%= time_ago_in_words(expense.created_at) %> ago</div>
                </td>
                <td>
                  <strong class="text-primary"><%= expense.store_name %></strong>
                  <div class="small text-muted"><%= expense.store_location %></div>
                </td>
                <td>
                  <strong><%= expense.title %></strong>
                  <% if expense.description.present? %>
                    <div class="small text-muted"><%= truncate(expense.description, length: 50) %></div>
                  <% end %>
                </td>
                <td>
                  <span class="badge bg-light text-dark">
                    <i class="<%= expense.category_icon %> me-1"></i>
                    <%= expense.category %>
                  </span>
                </td>
                <td>
                  <strong class="text-success"><%= expense.formatted_amount %></strong>
                </td>
                <td>
                  <small class="text-muted">
                    <i class="bi bi-person me-1"></i>
                    <%= expense.created_by.first_name %> <%= expense.created_by.last_name %>
                  </small>
                </td>
                <td>
                  <div class="btn-group" role="group">
                    <%= link_to admin_expense_path(expense), class: "btn btn-sm btn-outline-primary", title: "View" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_admin_expense_path(expense), class: "btn btn-sm btn-outline-secondary", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= link_to admin_expense_path(expense),
                        method: :delete,
                        data: {
                          confirm: "Are you sure you want to delete this expense from #{expense.store.name}?",
                          turbo_method: :delete
                        },
                        class: "btn btn-sm btn-outline-danger",
                        title: "Delete" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="card-footer bg-white border-0">
        <%= paginate @expenses %>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-receipt fs-1 text-muted mb-3"></i>
        <h5 class="text-muted">No Expenses Found</h5>
        <p class="text-muted">No expenses have been recorded for the selected criteria.</p>
      </div>
    <% end %>
  </div>
</div>

<!-- Category Breakdown (if monthly expenses exist) -->
<% if @category_breakdown.any? %>
  <div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white border-0">
      <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>This Month's Category Breakdown</h6>
    </div>
    <div class="card-body">
      <div class="row">
        <% @category_breakdown.each do |category, amount| %>
          <div class="col-md-4 col-lg-3 mb-3">
            <div class="d-flex align-items-center p-3 rounded bg-light">
              <div class="me-3">
                <div class="icon-bg bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                  <i class="<%= Expense.new(category: category).category_icon %>"></i>
                </div>
              </div>
              <div>
                <small class="text-muted d-block"><%= category %></small>
                <strong class="text-primary">₹<%= number_with_delimiter(amount.to_f.round(2)) %></strong>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<!-- Store Breakdown (if monthly expenses exist) -->
<% if @store_breakdown.any? %>
  <div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white border-0">
      <h6 class="mb-0"><i class="bi bi-shop me-2"></i>This Month's Store Breakdown</h6>
    </div>
    <div class="card-body">
      <div class="row">
        <% @store_breakdown.each do |store_name, amount| %>
          <div class="col-md-4 col-lg-3 mb-3">
            <div class="d-flex align-items-center p-3 rounded bg-light">
              <div class="me-3">
                <div class="icon-bg bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                  <i class="bi bi-shop"></i>
                </div>
              </div>
              <div>
                <small class="text-muted d-block"><%= truncate(store_name, length: 15) %></small>
                <strong class="text-success">₹<%= number_with_delimiter(amount.to_f.round(2)) %></strong>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>