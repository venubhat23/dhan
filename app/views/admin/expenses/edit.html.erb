<% content_for :page_title, "Edit Expense" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Edit Expense</h4>
    <small class="text-muted">Modify expense details from <%= @expense.store_name %></small>
  </div>
  <div>
    <%= link_to admin_expense_path(@expense), class: "btn btn-outline-secondary me-2" do %>
      <i class="bi bi-arrow-left me-2"></i>Back to Expense
    <% end %>
    <%= link_to admin_expenses_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-list me-2"></i>All Expenses
    <% end %>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Expense Details</h6>
      </div>
      <div class="card-body">
        <%= form_with model: [:admin, @expense], local: true, html: { class: "needs-validation", novalidate: true } do |f| %>
          <% if @expense.errors.any? %>
            <div class="alert alert-danger">
              <h6><i class="bi bi-exclamation-triangle me-2"></i>Please fix the following errors:</h6>
              <ul class="mb-0">
                <% @expense.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="row g-3">
            <!-- Title -->
            <div class="col-md-6">
              <label class="form-label">
                <i class="bi bi-card-text me-1"></i>Title <span class="text-danger">*</span>
              </label>
              <%= f.text_field :title, class: "form-control", placeholder: "Enter expense title", required: true %>
              <div class="invalid-feedback">Please provide a title for the expense.</div>
            </div>

            <!-- Category -->
            <div class="col-md-6">
              <label class="form-label">
                <i class="bi bi-tags me-1"></i>Category <span class="text-danger">*</span>
              </label>
              <%= f.select :category,
                  options_for_select(Expense::CATEGORIES.map { |cat| [cat, cat] }, @expense.category),
                  { prompt: "Select a category" },
                  { class: "form-select", required: true } %>
              <div class="invalid-feedback">Please select a category.</div>
            </div>

            <!-- Amount -->
            <div class="col-md-6">
              <label class="form-label">
                <i class="bi bi-currency-rupee me-1"></i>Amount <span class="text-danger">*</span>
              </label>
              <div class="input-group">
                <span class="input-group-text">₹</span>
                <%= f.number_field :amount, class: "form-control", step: 0.01, min: 0.01, placeholder: "0.00", required: true %>
              </div>
              <div class="invalid-feedback">Please enter a valid amount.</div>
            </div>

            <!-- Expense Date -->
            <div class="col-md-6">
              <label class="form-label">
                <i class="bi bi-calendar me-1"></i>Expense Date <span class="text-danger">*</span>
              </label>
              <%= f.date_field :expense_date, class: "form-control", required: true %>
              <div class="invalid-feedback">Please select the expense date.</div>
            </div>

            <!-- Description -->
            <div class="col-12">
              <label class="form-label">
                <i class="bi bi-file-text me-1"></i>Description
              </label>
              <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Enter additional details about this expense (optional)" %>
              <div class="form-text">Provide any additional details or notes about this expense.</div>
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <%= f.submit "Update Expense", class: "btn btn-primary" %>
            <%= link_to "Cancel", admin_expense_path(@expense), class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar Information -->
  <div class="col-lg-4">
    <!-- Location Information -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0">
          <i class="<%= @expense.is_main_inventory? ? 'bi bi-building' : 'bi bi-shop' %> me-2"></i>
          Location Information
        </h6>
      </div>
      <div class="card-body text-center">
        <div class="<%= @expense.is_main_inventory? ? 'bg-warning' : 'bg-primary' %> text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
          <i class="<%= @expense.is_main_inventory? ? 'bi bi-building' : 'bi bi-shop' %> fs-4"></i>
        </div>
        <h6 class="fw-bold"><%= @expense.store_name %></h6>
        <small class="text-muted">
          <%= @expense.store_location %>
        </small>
      </div>
    </div>

    <!-- Edit Guidelines -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Edit Guidelines</h6>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <h6 class="text-primary">Important Notes</h6>
          <ul class="list-unstyled small">
            <li><i class="bi bi-check-circle text-success me-1"></i>Double-check the amount before saving</li>
            <li><i class="bi bi-check-circle text-success me-1"></i>Ensure the category is appropriate</li>
            <li><i class="bi bi-check-circle text-success me-1"></i>Update description if needed</li>
            <li><i class="bi bi-check-circle text-success me-1"></i>Verify the expense date</li>
          </ul>
        </div>

        <div class="mb-3">
          <h6 class="text-primary">Categories Available</h6>
          <div class="small">
            <% Expense::CATEGORIES.first(6).each do |category| %>
              <span class="badge bg-light text-dark me-1 mb-1">
                <i class="<%= Expense.new(category: category).category_icon %> me-1"></i>
                <%= category %>
              </span>
            <% end %>
            <% if Expense::CATEGORIES.count > 6 %>
              <span class="text-muted small">+<%= Expense::CATEGORIES.count - 6 %> more...</span>
            <% end %>
          </div>
        </div>

        <div class="alert alert-warning small">
          <i class="bi bi-exclamation-triangle me-1"></i>
          Changes will be logged and tracked in the system.
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Form validation
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();
</script>