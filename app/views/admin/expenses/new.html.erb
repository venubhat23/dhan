<% content_for :page_title, "Add New Expense" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Add New Expense</h4>
    <small class="text-muted">Create a new expense record for any store</small>
  </div>
  <div>
    <%= link_to admin_expenses_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-2"></i>Back to Expenses
    <% end %>
  </div>
</div>

<!-- Form Card -->
<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Expense Details</h6>
      </div>
      <div class="card-body">
        <%= form_with model: [:admin, @expense], local: true, class: "needs-validation", novalidate: true do |form| %>
          <% if @expense.errors.any? %>
            <div class="alert alert-danger">
              <h6>Please fix the following errors:</h6>
              <ul class="mb-0">
                <% @expense.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="row">
            <!-- Store Selection -->
            <div class="col-md-12 mb-3">
              <%= form.label :store_id, "Store / Location", class: "form-label" %>
              <%= form.select :store_id,
                  options_for_select([
                    ["Select location", ""],
                    ["Main Inventory", "main_inventory"]
                  ] + @stores.map { |store| [store.name, store.id] }),
                  {},
                  { class: "form-select", required: true } %>
              <div class="invalid-feedback">
                Please select a store or Main Inventory.
              </div>
              <small class="text-muted">Choose "Main Inventory" for central warehouse expenses</small>
            </div>

            <!-- Title -->
            <div class="col-md-12 mb-3">
              <%= form.label :title, "Title", class: "form-label" %>
              <%= form.text_field :title,
                  class: "form-control",
                  placeholder: "Enter expense title",
                  required: true %>
              <div class="invalid-feedback">
                Please provide a title for the expense.
              </div>
            </div>

            <!-- Category -->
            <div class="col-md-6 mb-3">
              <%= form.label :category, "Category", class: "form-label" %>
              <%= form.select :category,
                  options_for_select([["Select category", ""]] + Expense::CATEGORIES.map { |cat| [cat, cat] }),
                  {},
                  { class: "form-select", required: true } %>
              <div class="invalid-feedback">
                Please select a category.
              </div>
            </div>

            <!-- Amount -->
            <div class="col-md-6 mb-3">
              <%= form.label :amount, "Amount (₹)", class: "form-label" %>
              <%= form.number_field :amount,
                  step: 0.01,
                  min: 0,
                  class: "form-control",
                  placeholder: "0.00",
                  required: true %>
              <div class="invalid-feedback">
                Please enter a valid amount.
              </div>
            </div>

            <!-- Expense Date -->
            <div class="col-md-12 mb-3">
              <%= form.label :expense_date, "Expense Date", class: "form-label" %>
              <%= form.date_field :expense_date,
                  value: Date.current,
                  class: "form-control",
                  required: true %>
              <div class="invalid-feedback">
                Please select the expense date.
              </div>
            </div>

            <!-- Description -->
            <div class="col-md-12 mb-3">
              <%= form.label :description, "Description (Optional)", class: "form-label" %>
              <%= form.text_area :description,
                  rows: 3,
                  class: "form-control",
                  placeholder: "Enter additional details about this expense..." %>
              <small class="text-muted">Optional: Provide more context about this expense</small>
            </div>
          </div>

          <!-- Form Actions -->
          <div class="d-flex justify-content-between align-items-center mt-4">
            <div>
              <%= link_to admin_expenses_path, class: "btn btn-outline-secondary" do %>
                <i class="bi bi-x me-1"></i>Cancel
              <% end %>
            </div>
            <div>
              <%= form.submit "Create Expense", class: "btn btn-primary" do %>
                <i class="bi bi-check me-1"></i>Create Expense
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- JavaScript for form validation -->
<script>
// Bootstrap form validation
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();
</script>