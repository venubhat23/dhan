<% content_for :page_title, "Expense Details" %>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Expense Details</h4>
    <small class="text-muted">View expense information from <%= @expense.store.name %></small>
  </div>
  <div>
    <%= link_to admin_expenses_path, class: "btn btn-outline-secondary me-2" do %>
      <i class="bi bi-arrow-left me-2"></i>Back to Expenses
    <% end %>
    <%= link_to edit_admin_expense_path(@expense), class: "btn btn-primary" do %>
      <i class="bi bi-pencil me-2"></i>Edit Expense
    <% end %>
  </div>
</div>

<div class="row">
  <!-- Main Expense Details -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <div class="d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-receipt me-2"></i>Expense Information</h6>
          <span class="badge bg-light text-dark">
            <i class="<%= @expense.category_icon %> me-1"></i>
            <%= @expense.category %>
          </span>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-4">
          <!-- Title -->
          <div class="col-md-6">
            <div class="info-item">
              <label class="form-label text-muted small mb-1">
                <i class="bi bi-card-text me-1"></i>Title
              </label>
              <div class="fw-bold"><%= @expense.title %></div>
            </div>
          </div>

          <!-- Amount -->
          <div class="col-md-6">
            <div class="info-item">
              <label class="form-label text-muted small mb-1">
                <i class="bi bi-currency-rupee me-1"></i>Amount
              </label>
              <div class="fw-bold text-success fs-5"><%= @expense.formatted_amount %></div>
            </div>
          </div>

          <!-- Expense Date -->
          <div class="col-md-6">
            <div class="info-item">
              <label class="form-label text-muted small mb-1">
                <i class="bi bi-calendar me-1"></i>Expense Date
              </label>
              <div class="fw-bold"><%= @expense.expense_date.strftime('%d %B %Y') %></div>
            </div>
          </div>

          <!-- Category -->
          <div class="col-md-6">
            <div class="info-item">
              <label class="form-label text-muted small mb-1">
                <i class="bi bi-tags me-1"></i>Category
              </label>
              <div>
                <span class="badge bg-primary">
                  <i class="<%= @expense.category_icon %> me-1"></i>
                  <%= @expense.category %>
                </span>
              </div>
            </div>
          </div>

          <!-- Description -->
          <% if @expense.description.present? %>
            <div class="col-12">
              <div class="info-item">
                <label class="form-label text-muted small mb-1">
                  <i class="bi bi-file-text me-1"></i>Description
                </label>
                <div class="bg-light p-3 rounded">
                  <%= simple_format(@expense.description) %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Sidebar Information -->
  <div class="col-lg-4">
    <!-- Store Information -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-shop me-2"></i>Store Information</h6>
      </div>
      <div class="card-body">
        <div class="text-center mb-3">
          <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
            <i class="bi bi-shop fs-4"></i>
          </div>
          <h6 class="fw-bold"><%= @expense.store.name %></h6>
          <small class="text-muted">
            <%= @expense.store.city %>, <%= @expense.store.state %>
          </small>
        </div>

        <hr>

        <div class="small">
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Contact Person:</span>
            <span class="fw-bold"><%= @expense.store.contact_person %></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Mobile:</span>
            <span class="fw-bold"><%= @expense.store.contact_mobile %></span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-muted">Status:</span>
            <span class="badge <%= @expense.store.status? ? 'bg-success' : 'bg-danger' %>">
              <%= @expense.store.status? ? 'Active' : 'Inactive' %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Created By Information -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-person me-2"></i>Created By</h6>
      </div>
      <div class="card-body">
        <div class="text-center mb-3">
          <div class="bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 50px; height: 50px;">
            <i class="bi bi-person fs-5"></i>
          </div>
          <h6 class="fw-bold">
            <%= @expense.created_by.first_name %> <%= @expense.created_by.last_name %>
          </h6>
          <small class="text-muted"><%= @expense.created_by.user_type.humanize %></small>
        </div>

        <hr>

        <div class="small">
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Email:</span>
            <span class="fw-bold"><%= @expense.created_by.email %></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Created:</span>
            <span class="fw-bold"><%= @expense.created_at.strftime('%d %b %Y, %I:%M %p') %></span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-muted">Last Updated:</span>
            <span class="fw-bold"><%= @expense.updated_at.strftime('%d %b %Y, %I:%M %p') %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0">
        <h6 class="mb-0"><i class="bi bi-gear me-2"></i>Actions</h6>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <%= link_to edit_admin_expense_path(@expense), class: "btn btn-outline-primary" do %>
            <i class="bi bi-pencil me-2"></i>Edit Expense
          <% end %>

          <%= link_to admin_expense_path(@expense),
              method: :delete,
              data: {
                confirm: "Are you sure you want to delete this expense? This action cannot be undone.",
                turbo_method: :delete
              },
              class: "btn btn-outline-danger" do %>
            <i class="bi bi-trash me-2"></i>Delete Expense
          <% end %>

          <%= link_to admin_expenses_path, class: "btn btn-outline-secondary" do %>
            <i class="bi bi-arrow-left me-2"></i>Back to List
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.info-item {
  margin-bottom: 1rem;
}

.info-item label {
  display: block;
  margin-bottom: 0.25rem;
  font-weight: 600;
}

.card {
  border-radius: 12px !important;
}

.card-header {
  border-radius: 12px 12px 0 0 !important;
}
</style>