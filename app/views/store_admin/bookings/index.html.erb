<%- content_for :title, "Bookings - #{@current_store.name}" %>
<%- content_for :breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Dashboard", store_admin_root_path %></li>
  <li class="breadcrumb-item active">Bookings</li>
<%- end %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="card-title mb-0">Store Bookings - <%= @current_store.name %></h4>
        <%= link_to "New Booking", new_store_admin_booking_path, class: "btn btn-primary" %>
      </div>

      <div class="card-body">
        <!-- Booking Summary Cards -->
        <div class="row mb-4">
          <div class="col-md-3">
            <div class="card bg-primary text-white">
              <div class="card-body">
                <h5 class="card-title">Total Bookings</h5>
                <h3 class="mb-0"><%= @summary[:total_bookings] %></h3>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card bg-warning text-white">
              <div class="card-body">
                <h5 class="card-title">Pending</h5>
                <h3 class="mb-0"><%= @summary[:pending_bookings] %></h3>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card bg-info text-white">
              <div class="card-body">
                <h5 class="card-title">Processing</h5>
                <h3 class="mb-0"><%= @summary[:processing_bookings] %></h3>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card bg-success text-white">
              <div class="card-body">
                <h5 class="card-title">Completed</h5>
                <h3 class="mb-0"><%= @summary[:completed_bookings] %></h3>
              </div>
            </div>
          </div>
        </div>

        <!-- Filters -->
        <%= form_with url: store_admin_bookings_path, method: :get, local: true, class: "mb-3" do |form| %>
          <div class="row">
            <div class="col-md-3">
              <%= form.text_field :search, value: params[:search], placeholder: "Search bookings...", class: "form-control" %>
            </div>
            <div class="col-md-3">
              <%= form.select :status,
                  options_for_select([["All Statuses", ""]] + Booking.statuses.keys.map { |s| [s.humanize, s] }, params[:status]),
                  {}, { class: "form-select" } %>
            </div>
            <div class="col-md-2">
              <%= form.date_field :date_from, value: params[:date_from], class: "form-control", placeholder: "From Date" %>
            </div>
            <div class="col-md-2">
              <%= form.date_field :date_to, value: params[:date_to], class: "form-control", placeholder: "To Date" %>
            </div>
            <div class="col-md-2">
              <%= form.submit "Filter", class: "btn btn-outline-primary w-100" %>
            </div>
          </div>
        <% end %>

        <!-- Bookings Table -->
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Booking #</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total Amount</th>
                <th>Payment Status</th>
                <th>Booking Status</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @bookings.each do |booking| %>
                <tr>
                  <td>
                    <strong><%= booking.booking_number || "##{booking.id}" %></strong>
                  </td>
                  <td>
                    <% if booking.customer %>
                      <%= booking.customer.display_name %><br>
                      <small class="text-muted"><%= booking.customer.mobile %></small>
                    <% else %>
                      <span class="text-muted">Walk-in Customer</span>
                    <% end %>
                  </td>
                  <td>
                    <% booking.booking_items.includes(:product).each do |item| %>
                      <small class="d-block"><%= item.product.name %> (×<%= item.quantity %>)</small>
                    <% end %>
                  </td>
                  <td>
                    <strong>₹<%= number_with_precision(booking.total_amount || 0, precision: 2) %></strong>
                  </td>
                  <td>
                    <% if booking.payment_status == 'paid' %>
                      <span class="badge bg-success">Paid</span>
                    <% else %>
                      <span class="badge bg-warning">Unpaid</span>
                    <% end %>
                  </td>
                  <td>
                    <% if booking.status.present? %>
                      <% case booking.status %>
                      <% when 'draft', 'ordered_and_delivery_pending' %>
                        <span class="badge bg-warning"><%= booking.status.humanize %></span>
                      <% when 'confirmed', 'processing', 'packed' %>
                        <span class="badge bg-info"><%= booking.status.humanize %></span>
                      <% when 'shipped', 'out_for_delivery' %>
                        <span class="badge bg-primary"><%= booking.status.humanize %></span>
                      <% when 'delivered', 'completed' %>
                        <span class="badge bg-success"><%= booking.status.humanize %></span>
                      <% when 'cancelled', 'returned' %>
                        <span class="badge bg-danger"><%= booking.status.humanize %></span>
                      <% else %>
                        <span class="badge bg-secondary"><%= booking.status.humanize %></span>
                      <% end %>
                    <% else %>
                      <span class="badge bg-secondary">No Status</span>
                    <% end %>
                  </td>
                  <td>
                    <%= booking.created_at.strftime("%d %b %Y") %><br>
                    <small class="text-muted"><%= booking.created_at.strftime("%I:%M %p") %></small>
                  </td>
                  <td>
                    <div class="btn-group btn-group-sm" role="group">
                      <%= link_to "View", store_admin_booking_path(booking), class: "btn btn-outline-primary" %>
                      <% if ['draft', 'confirmed'].include?(booking.status) %>
                        <%= link_to "Edit", edit_store_admin_booking_path(booking), class: "btn btn-outline-secondary" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>

              <% if @bookings.empty? %>
                <tr>
                  <td colspan="8" class="text-center py-4">
                    <div class="text-muted">
                      <i class="fas fa-clipboard-list fa-3x mb-3"></i>
                      <h5>No bookings found</h5>
                      <p>No bookings match your current filters or there are no bookings yet.</p>
                      <%= link_to "Create First Booking", new_store_admin_booking_path, class: "btn btn-primary" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if @bookings.respond_to?(:current_page) %>
          <div class="d-flex justify-content-center mt-3">
            <%= paginate @bookings %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>