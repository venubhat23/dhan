<%- content_for :title, "Booking Details - #{@booking.booking_number || "##{@booking.id}"}" %>
<%- content_for :breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Dashboard", store_admin_root_path %></li>
  <li class="breadcrumb-item"><%= link_to "Bookings", store_admin_bookings_path %></li>
  <li class="breadcrumb-item active">Booking #<%= @booking.booking_number || @booking.id %></li>
<%- end %>

<div class="row">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="card-title mb-0">Booking Details</h4>
        <div class="d-flex gap-2">
          <button onclick="window.print()" class="btn btn-success btn-sm">
            <i class="fas fa-print me-1"></i>Print Bill
          </button>
          <% if ['draft', 'confirmed'].include?(@booking.status) %>
            <%= link_to "Edit", edit_store_admin_booking_path(@booking), class: "btn btn-outline-primary btn-sm" %>
          <% end %>
          <%= link_to "Back to Bookings", store_admin_bookings_path, class: "btn btn-outline-secondary btn-sm" %>
        </div>
      </div>

      <div class="card-body">
        <!-- Booking Information -->
        <div class="row mb-4">
          <div class="col-md-6">
            <h6 class="fw-semibold">Booking Information</h6>
            <table class="table table-borderless table-sm">
              <tr>
                <td><strong>Booking Number:</strong></td>
                <td><%= @booking.booking_number || "##{@booking.id}" %></td>
              </tr>
              <tr>
                <td><strong>Store:</strong></td>
                <td><%= @current_store.name %></td>
              </tr>
              <tr>
                <td><strong>Date:</strong></td>
                <td><%= @booking.created_at.strftime("%d %b %Y at %I:%M %p") %></td>
              </tr>
              <tr>
                <td><strong>Status:</strong></td>
                <td>
                  <% if @booking.status.present? %>
                    <% case @booking.status %>
                    <% when 'draft', 'ordered_and_delivery_pending' %>
                      <span class="badge bg-warning"><%= @booking.status.humanize %></span>
                    <% when 'confirmed', 'processing', 'packed' %>
                      <span class="badge bg-info"><%= @booking.status.humanize %></span>
                    <% when 'shipped', 'out_for_delivery' %>
                      <span class="badge bg-primary"><%= @booking.status.humanize %></span>
                    <% when 'delivered', 'completed' %>
                      <span class="badge bg-success"><%= @booking.status.humanize %></span>
                    <% when 'cancelled', 'returned' %>
                      <span class="badge bg-danger"><%= @booking.status.humanize %></span>
                    <% else %>
                      <span class="badge bg-secondary"><%= @booking.status.humanize %></span>
                    <% end %>
                  <% else %>
                    <span class="badge bg-secondary">Unknown</span>
                  <% end %>
                </td>
              </tr>
              <tr>
                <td><strong>Payment Status:</strong></td>
                <td>
                  <% if @booking.payment_status == 'paid' %>
                    <span class="badge bg-success">Paid</span>
                  <% else %>
                    <span class="badge bg-warning">Unpaid</span>
                  <% end %>
                </td>
              </tr>
            </table>
          </div>

          <div class="col-md-6">
            <h6 class="fw-semibold">Customer Information</h6>
            <% if @booking.customer %>
              <table class="table table-borderless table-sm">
                <tr>
                  <td><strong>Name:</strong></td>
                  <td><%= @booking.customer.display_name %></td>
                </tr>
                <tr>
                  <td><strong>Mobile:</strong></td>
                  <td><%= @booking.customer.mobile %></td>
                </tr>
                <tr>
                  <td><strong>Email:</strong></td>
                  <td><%= @booking.customer.email || 'N/A' %></td>
                </tr>
              </table>
            <% else %>
              <p class="text-muted">Walk-in Customer</p>
            <% end %>
          </div>
        </div>

        <!-- Booking Items -->
        <div class="mb-4">
          <h6 class="fw-semibold">Ordered Items</h6>
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Quantity</th>
                  <th>Unit Price</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% @booking.booking_items.includes(:product).each do |item| %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <% if item.product.image.present? %>
                          <%= image_tag item.product.image, class: "rounded me-2", style: "width: 40px; height: 40px; object-fit: cover;" %>
                        <% end %>
                        <div>
                          <h6 class="mb-0"><%= item.product.name %></h6>
                          <small class="text-muted">SKU: <%= item.product.sku || 'N/A' %></small>
                        </div>
                      </div>
                    </td>
                    <td><%= item.quantity %> <%= item.product.unit_type %></td>
                    <td>₹<%= number_with_precision(item.price || 0, precision: 2) %></td>
                    <td><strong>₹<%= number_with_precision((item.quantity * (item.price || 0)), precision: 2) %></strong></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Notes -->
        <% if @booking.notes.present? %>
          <div class="mb-4">
            <h6 class="fw-semibold">Notes</h6>
            <div class="border rounded p-3 bg-light">
              <%= simple_format(@booking.notes) %>
            </div>
          </div>
        <% end %>

        <!-- Order Total (visible on print) -->
        <div class="d-print-block d-none">
          <div class="row justify-content-end mt-4">
            <div class="col-md-6">
              <table class="table table-borderless">
                <tr>
                  <td>Subtotal:</td>
                  <td class="text-end">₹<%= number_with_precision(@booking.subtotal || 0, precision: 2) %></td>
                </tr>
                <% if @booking.discount_amount.to_f > 0 %>
                  <tr>
                    <td>Discount:</td>
                    <td class="text-end text-success">-₹<%= number_with_precision(@booking.discount_amount || 0, precision: 2) %></td>
                  </tr>
                <% end %>
                <% if @booking.tax_amount.to_f > 0 %>
                  <tr>
                    <td>Tax:</td>
                    <td class="text-end">₹<%= number_with_precision(@booking.tax_amount || 0, precision: 2) %></td>
                  </tr>
                <% end %>
                <tr class="border-top">
                  <td><strong>Total Amount:</strong></td>
                  <td class="text-end"><strong>₹<%= number_with_precision(@booking.total_amount || 0, precision: 2) %></strong></td>
                </tr>
                <tr>
                  <td><strong>Payment Method:</strong></td>
                  <td class="text-end text-capitalize"><%= @booking.payment_method || 'Cash' %></td>
                </tr>
                <tr>
                  <td><strong>Payment Status:</strong></td>
                  <td class="text-end">
                    <% if @booking.payment_status == 'paid' %>
                      Paid
                    <% else %>
                      Unpaid
                    <% end %>
                  </td>
                </tr>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Order Summary Sidebar -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Order Summary</h5>
      </div>
      <div class="card-body">
        <table class="table table-borderless">
          <tr>
            <td>Subtotal:</td>
            <td class="text-end">₹<%= number_with_precision(@booking.subtotal || 0, precision: 2) %></td>
          </tr>
          <% if @booking.discount_amount.to_f > 0 %>
            <tr>
              <td>Discount:</td>
              <td class="text-end text-success">-₹<%= number_with_precision(@booking.discount_amount || 0, precision: 2) %></td>
            </tr>
          <% end %>
          <% if @booking.tax_amount.to_f > 0 %>
            <tr>
              <td>Tax:</td>
              <td class="text-end">₹<%= number_with_precision(@booking.tax_amount || 0, precision: 2) %></td>
            </tr>
          <% end %>
          <tr class="border-top">
            <td><strong>Total Amount:</strong></td>
            <td class="text-end"><strong>₹<%= number_with_precision(@booking.total_amount || 0, precision: 2) %></strong></td>
          </tr>
        </table>

        <div class="mt-3">
          <strong>Payment Method:</strong>
          <span class="ms-2 text-capitalize"><%= @booking.payment_method || 'Cash' %></span>
        </div>
      </div>
    </div>

    <!-- Status Update Actions -->
    <% if @can_update_status && @available_statuses.any? %>
      <div class="card mt-3">
        <div class="card-header">
          <h5 class="card-title mb-0">Update Status</h5>
        </div>
        <div class="card-body">
          <p class="small text-muted">Current Status: <strong><%= @booking.status&.humanize || 'Unknown' %></strong></p>

          <%= form_with url: update_status_store_admin_booking_path(@booking), method: :patch, local: true do |form| %>
            <div class="mb-3">
              <%= form.select :new_status,
                  options_for_select(@available_statuses.map { |s| [s.humanize, s] }),
                  { prompt: "Select new status..." },
                  { class: "form-select" } %>
            </div>

            <% if @available_statuses.include?('shipped') %>
              <div class="mb-3" id="tracking-field" style="display: none;">
                <%= form.text_field :tracking_number, placeholder: "Enter tracking number...", class: "form-control" %>
              </div>
            <% end %>

            <%= form.submit "Update Status", class: "btn btn-primary w-100" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Cancel Booking -->
    <% if ['draft', 'confirmed'].include?(@booking.status) %>
      <div class="card mt-3">
        <div class="card-header bg-light">
          <h5 class="card-title mb-0 text-danger">Cancel Booking</h5>
        </div>
        <div class="card-body">
          <%= form_with url: cancel_store_admin_booking_path(@booking), method: :patch, local: true do |form| %>
            <div class="mb-3">
              <%= form.text_area :cancellation_reason, placeholder: "Reason for cancellation...", class: "form-control", rows: 3, required: true %>
            </div>
            <%= form.submit "Cancel Booking", class: "btn btn-danger w-100",
                confirm: "Are you sure you want to cancel this booking? This action cannot be undone." %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
@media print {
  /* Hide elements that shouldn't be printed */
  .btn, .breadcrumb, .card-header .d-flex, .sidebar, .navbar, .footer {
    display: none !important;
  }

  /* Hide the sidebar with order summary and actions when printing */
  .col-lg-4 {
    display: none !important;
  }

  /* Make the main content take full width when printing */
  .col-lg-8 {
    flex: 0 0 100% !important;
    max-width: 100% !important;
  }

  /* Clean up the card styling for print */
  .card {
    border: none !important;
    box-shadow: none !important;
  }

  .card-header {
    background: none !important;
    border: none !important;
    padding: 0 0 15px 0 !important;
  }

  .card-body {
    padding: 0 !important;
  }

  /* Make sure the bill content is clean */
  body {
    background: white !important;
    font-size: 12px !important;
  }

  /* Add a header for the printed bill */
  .card-header h4:after {
    content: "\A\A" attr(data-store-name) "\A" attr(data-store-address);
    white-space: pre;
    display: block;
    font-size: 14px;
    font-weight: normal;
    margin-top: 10px;
    border-bottom: 1px solid #000;
    padding-bottom: 10px;
  }

  /* Style the tables for better printing */
  table {
    width: 100% !important;
    border-collapse: collapse !important;
  }

  table td, table th {
    border: 1px solid #ddd !important;
    padding: 8px !important;
    font-size: 11px !important;
  }

  table th {
    background-color: #f8f9fa !important;
    font-weight: bold !important;
  }

  /* Hide images in print to save space */
  img {
    display: none !important;
  }

  /* Add page break before order summary */
  .table-responsive {
    page-break-inside: avoid !important;
  }
}
</style>

<script>
// Show tracking number field when shipped status is selected
document.addEventListener('change', function(e) {
  if (e.target.name === 'new_status') {
    const trackingField = document.getElementById('tracking-field');
    if (trackingField) {
      if (e.target.value === 'shipped') {
        trackingField.style.display = 'block';
      } else {
        trackingField.style.display = 'none';
      }
    }
  }
});
</script>