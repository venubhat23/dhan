<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Store Admin - <%= @current_store&.name || 'Store Management' %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    .store-admin-sidebar {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
    }

    .store-admin-nav-link {
      color: rgba(255,255,255,0.85);
      padding: 0.75rem 1rem;
      border-radius: 0.375rem;
      margin-bottom: 0.25rem;
      transition: all 0.2s ease;
    }

    .store-admin-nav-link:hover {
      background: rgba(255,255,255,0.15);
      color: white;
    }

    .store-admin-nav-link.active {
      background: rgba(255,255,255,0.2);
      color: white;
    }

    .store-info-card {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      backdrop-filter: blur(10px);
    }

    .metric-card {
      transition: transform 0.2s ease;
    }

    .metric-card:hover {
      transform: translateY(-2px);
    }
  </style>
</head>

<body class="bg-light">
  <div class="container-fluid p-0">
    <div class="row g-0">
      <!-- Sidebar -->
      <nav class="col-md-3 col-lg-2 d-md-block store-admin-sidebar">
        <div class="position-sticky pt-3 pb-3">
          <!-- Store Info -->
          <div class="px-3 mb-4">
            <div class="store-info-card rounded p-3 text-white">
              <h6 class="mb-1"><%= @current_store&.name %></h6>
              <small class="opacity-75"><%= @current_store&.city %></small>
              <div class="mt-2 small">
                <i class="bi bi-person-circle me-1"></i>
                <%= current_user.full_name %>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <ul class="nav flex-column px-3">
            <li class="nav-item">
              <%= link_to store_admin_root_path,
                  class: "nav-link store-admin-nav-link #{'active' if current_page?(store_admin_root_path)}" do %>
                <i class="bi bi-speedometer2 me-2"></i>
                Dashboard
              <% end %>
            </li>

            <% if store_admin_sidebar_permissions['inventory'] %>
              <li class="nav-item">
                <%= link_to store_admin_inventory_index_path,
                    class: "nav-link store-admin-nav-link #{'active' if controller_name == 'inventory'}" do %>
                  <i class="bi bi-boxes me-2"></i>
                  Inventory
                <% end %>
              </li>
            <% end %>

            <% if store_admin_sidebar_permissions['bookings'] %>
              <li class="nav-item">
                <%= link_to store_admin_bookings_path,
                    class: "nav-link store-admin-nav-link #{'active' if controller_name == 'bookings'}" do %>
                  <i class="bi bi-cart-check me-2"></i>
                  Bookings
                <% end %>
              </li>
            <% end %>

            <% if store_admin_sidebar_permissions['transfers'] %>
              <li class="nav-item">
                <%= link_to store_admin_transfers_path,
                    class: "nav-link store-admin-nav-link #{'active' if controller_name == 'transfers'}" do %>
                  <i class="bi bi-arrow-left-right me-2"></i>
                  Transfers
                <% end %>
              </li>
            <% end %>

            <% if store_admin_sidebar_permissions['customers'] %>
              <li class="nav-item">
                <%= link_to store_admin_customers_path,
                    class: "nav-link store-admin-nav-link #{'active' if controller_name == 'customers'}" do %>
                  <i class="bi bi-people me-2"></i>
                  Customers
                <% end %>
              </li>
            <% end %>

            <% if store_admin_sidebar_permissions['reports'] %>
              <li class="nav-item">
                <%= link_to store_admin_reports_path,
                    class: "nav-link store-admin-nav-link #{'active' if controller_name == 'reports'}" do %>
                  <i class="bi bi-graph-up me-2"></i>
                  Reports
                <% end %>
              </li>
            <% end %>
          </ul>

          <!-- Footer -->
          <div class="px-3 mt-4 pt-3 border-top border-light border-opacity-25">
            <div class="d-grid gap-2">
              <%= link_to "Back to Admin", admin_stores_path,
                  class: "btn btn-outline-light btn-sm" if current_user.admin? %>
              <%= link_to "Logout", destroy_user_session_path,
                  method: :delete,
                  class: "btn btn-outline-light btn-sm",
                  data: {
                    confirm: "Are you sure you want to logout?",
                    turbo_method: :delete
                  } %>
            </div>
          </div>
        </div>
      </nav>

      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10">
        <!-- Top Bar -->
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 px-3 border-bottom">
          <h1 class="h2">
            <% if content_for?(:page_title) %>
              <%= content_for(:page_title) %>
            <% else %>
              Store Management
            <% end %>
          </h1>

          <div class="btn-toolbar mb-2 mb-md-0">
            <div class="btn-group me-2">
              <span class="badge bg-primary">
                <%= @current_store&.name %>
              </span>
            </div>
          </div>
        </div>

        <!-- Flash Messages -->
        <div class="px-3">
          <% if notice %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
              <%= notice %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>

          <% if alert %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <%= alert %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>
        </div>

        <!-- Page Content -->
        <div class="px-3">
          <%= yield %>
        </div>
      </main>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>